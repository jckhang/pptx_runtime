pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "#0F172A"

  - elementId: accent-stripe
    elementType: shape
    bounds: [0, 4, 1280, 2]
    shapeName: rect
    fill:
      type: solid
      color: "#B45309"

  # ── Title accent bar ──
  - elementId: toc-accent-bar
    elementType: shape
    bounds: [80, 48, 60, 4]
    shapeName: rect
    fill:
      type: solid
      color: "#B45309"

  # ── Title ──
  - elementId: toc-title
    elementType: text
    bounds: [80, 60, 300, 44]
    content:
      fontSize: 32
      color: "#1E293B"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>CONTENTS</strong></p>

  # ── Watermark text ──
