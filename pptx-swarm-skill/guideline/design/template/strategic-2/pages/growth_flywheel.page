pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "#0F172A"

  - elementId: accent-stripe
    elementType: shape
    bounds: [0, 4, 1280, 2]
    shapeName: rect
    fill:
      type: solid
      color: "#B45309"

  - elementId: title-accent-mark
    elementType: shape
    bounds: [80, 28, 4, 32]
    shapeName: rect
    fill:
      type: solid
      color: "#B45309"

  - elementId: page-title
    elementType: text
    bounds: [96, 24, 1100, 40]
    content:
      fontSize: 28
      color: "#1E293B"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>增长飞轮：数据驱动的自增强循环</strong></p>

  - elementId: title-line
    elementType: shape
    bounds: [80, 70, 1120, 1]
    shapeName: rect
    fill:
      type: solid
      color: "#E2E8F0"

  # ===== Center flywheel =====
  - elementId: flywheel-center-bg
    elementType: shape
    bounds: [490, 285, 300, 130]
    shapeName: ellipse
    fill:
      type: solid
      color: "#0F172A"

  - elementId: flywheel-center-text
    elementType: text
    bounds: [490, 300, 300, 100]
    content:
      fontSize: 22
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: true
      text: |
        <p><strong>数据飞轮</strong></p>
        <p><span style="font-size:13px; color:#FFFFFF80;">Data Flywheel</span></p>

  # ===== Card 1: Top center — 客户获取与使用 =====
  - elementId: card-1-bg
    elementType: shape
    bounds: [390, 90, 500, 80]
    shapeName: roundRect
