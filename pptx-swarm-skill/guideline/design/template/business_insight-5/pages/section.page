        <p><span style="font-size:15px; color:#1A1A1A; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>关键论点二</strong></span></p>
        <p><span style="font-size:13px; color:#555555; font-family:Liter, MiSans;">此处填写该章节第二个关键论点，体现市场结构或竞争态势的变化逻辑</span></p>

  - elementId: kp2-sep
    elementType: shape
    bounds: [530, 308, 700, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  - elementId: kp3-num-bg
