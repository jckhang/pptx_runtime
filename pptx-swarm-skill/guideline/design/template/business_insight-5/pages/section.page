        <p><span style="font-size:32px; color:#8C1515; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>XX个</strong></span></p>

  - elementId: kpi3-desc
    elementType: text
    bounds: [1010, 510, 220, 18]
    content:
      align: [left, middle]
      fontSize: 12
      color: "$medgray"
      wrap: false
      text: |
        <p>核心指标三</p>

  # Footer
  - elementId: footer-line
    elementType: shape
    bounds: [530, 658, 700, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  - elementId: page-num
    elementType: text
