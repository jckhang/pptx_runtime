    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:22px; color:#FFFFFF; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>3</strong></span></p>

  - elementId: kp3-text
    elementType: text
    bounds: [578, 322, 650, 80]
    content:
      fontSize: 14
      color: "$text"
      lineHeight: 1.6
      wrap: true
      text: |
        <p><span style="font-size:15px; color:#1A1A1A; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>关键论点三</strong></span></p>
        <p><span style="font-size:13px; color:#555555; font-family:Liter, MiSans;">此处填写该章节第三个关键论点，指向战略建议或投资启示</span></p>

  - elementId: kp3-sep
