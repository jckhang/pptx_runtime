pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 左侧深紫色块（含水印）
  - elementId: toc-left-bg
    elementType: shape
    bounds: [0, 0, 360, 720]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 180
      stops:
        - {position: 0, color: "#2D1B55"}
        - {position: 1, color: "#432879"}

  # 左侧水印大字
  - elementId: toc-watermark
    elementType: text
    bounds: [0, 400, 360, 200]
    content:
      fontSize: 60
      color: "#FFFFFF08"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: CONTENTS

  # 左侧标题
  - elementId: toc-left-title
    elementType: text
    bounds: [36, 290, 290, 60]
    content:
      fontSize: 44
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>目录</strong></p>

  - elementId: toc-left-title-en
    elementType: text
    bounds: [36, 355, 290, 26]
    content:
      fontSize: 14
      color: "#8A7BB5"
      fontFamily: "QuattrocentoSans, MiSans"
      letterSpacing: 3
      wrap: false
      text: TABLE OF CONTENTS

  # 左侧细横线装饰
  - elementId: toc-left-sep
    elementType: shape
    bounds: [36, 282, 80, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "#8A7BB5"

  # 右侧目录项
  - elementId: toc-num-1
    elementType: text
    bounds: [390, 130, 72, 52]
    content:
      fontSize: 42
      color: "$accent"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
