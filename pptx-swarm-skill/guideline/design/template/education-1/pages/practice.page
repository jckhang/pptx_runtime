pageType: content
background:
  type: solid
  color: $background
elements:
  - elementId: page-title
    elementType: text
    bounds:
      - 80
      - 60
      - 800
      - 50
    content:
      style: $title
      align:
        - left
        - middle
      text: |
        <p>实践挑战：将所学应用于真实情境</p>
  - elementId: challenge-container
    elementType: shape
    bounds:
      - 80
      - 140
      - 1120
      - 400
    shapeName: roundRect
    adjustments:
      - 8000
    fill:
      type: solid
      color: $card
    shadow:
      blur: 10
      color: "#00000010"
      offset:
        - 0
        - 3
  - elementId: challenge-header
    elementType: shape
    bounds:
      - 80
      - 140
      - 1120
      - 80
    shapeName: roundRect
    adjustments:
      - 8000
    fill:
      type: gradient
      gradientType: linear
      angle: 90
      stops:
        - position: 0
          color: $accent
        - position: 1
          color: $accent2
  - elementId: challenge-icon
    elementType: icon
    bounds:
      - 120
      - 160
      - 40
      - 40
    iconName: fas:rocket
    fill:
      type: solid
      color: $textWhite
  - elementId: challenge-title
    elementType: text
    bounds:
      - 180
      - 150
      - 900
      - 60
    content:
      fontSize: 26
      color: $textWhite
      fontFamily: Liter, MiSans
      align:
        - left
        - middle
      text: |
        <p><strong>30天学习挑战：构建你的专业知识体系</strong></p>
  - elementId: challenge-grid
    elementType: shape
    bounds:
      - 110
      - 250
      - 1060
      - 260
    shapeName: rect
    fill:
      type: solid
      color: "#FFFFFF00"
  - elementId: week1-card
    elementType: shape
    bounds:
      - 130
      - 270
      - 240
      - 220
    shapeName: roundRect
    adjustments:
      - 8000
    fill:
      type: solid
      color: $background
    border:
      style: solid
      width: 2
      color: $accent
  - elementId: week1-title
    elementType: text
    bounds:
      - 150
      - 290
      - 200
      - 40
    content:
      fontSize: 20
      color: $accent
      fontFamily: Liter, MiSans
      align:
        - center
        - middle
      text: |
        <p><strong>第1周：基础</strong></p>
