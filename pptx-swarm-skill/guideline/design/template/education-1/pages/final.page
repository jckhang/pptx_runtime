      fontSize: 24
      color: "#E0E0E0"
      fontFamily: Liter, MiSans
      align:
        - center
        - middle
      text: |
        <p>学习是一场没有终点的旅程</p>
  - elementId: action-container
    elementType: shape
    bounds:
      - 340
      - 370
      - 600
      - 220
    opacity: 0.1
