pageType: final
background:
  type: solid
  color: $primary
elements:
  - elementId: bg-circle1
    elementType: shape
    bounds:
      - -100
      - -100
      - 400
      - 400
    opacity: 0.05
    shapeName: ellipse
    fill:
      type: solid
      color: "#FFFFFF"
  - elementId: bg-circle2
    elementType: shape
