      fontSize: 56
      color: $textWhite
      fontFamily: Liter, MiSans
      align:
        - center
        - middle
      text: |
        <p>下一步：巩固与深化</p>
  - elementId: subtitle
    elementType: text
    bounds:
      - 240
      - 300
      - 800
      - 40
