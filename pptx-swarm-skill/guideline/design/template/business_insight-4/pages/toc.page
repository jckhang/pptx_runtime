  # Right sidebar: Summary panel
  - elementId: summary-panel-bg
    elementType: shape
    bounds: [720, 100, 500, 440]
    shapeName: rect
    fill:
      type: solid
      color: "$lightblue"

  - elementId: summary-panel-title
    elementType: text
    bounds: [744, 120, 460, 28]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:16px; color:#1B3A6B; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>核心结论摘要 KEY FINDINGS</strong></span></p>

  - elementId: summary-panel-sep
    elementType: shape
    bounds: [744, 154, 200, 2]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: summary-panel-text
    elementType: text
    bounds: [744, 172, 460, 350]
    content:
      fontSize: 15
      color: "$text"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.7
      wrap: true
      text: |
        <p><span style="font-size:15px; font-family:Liter, MiSans;"><strong>市场规模</strong></span></p>
        <p><span style="font-size:14px; font-family:Liter, MiSans;">2025E达¥2.8万亿（+18.6% YoY），增长动能从政策驱动转向消费内生</span></p>
        <p></p>
        <p><span style="font-size:15px; font-family:Liter, MiSans;"><strong>竞争格局</strong></span></p>
        <p><span style="font-size:14px; font-family:Liter, MiSans;">头部集中加速，CR5突破62%，竞争格局基本锁定，尾部品牌加速出清</span></p>
        <p></p>
        <p><span style="font-size:15px; font-family:Liter, MiSans;"><strong>投资建议</strong></span></p>
        <p><span style="font-size:14px; font-family:Liter, MiSans;">建议超配龙头标的，关注技术壁垒与现金流质量，目标收益率15-25%</span></p>

  # Footer
  - elementId: footer-line
    elementType: shape
    bounds: [60, 660, 1160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$border"

  - elementId: page-number
    elementType: text
    bounds: [1140, 668, 80, 22]
    content:
      align: [right, middle]
      fontSize: 13
      color: "$medgray"
      wrap: false
      text: |
        <p>02</p>
