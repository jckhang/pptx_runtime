pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # Top primary bar
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 5]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # Gold accent bar
  - elementId: gold-accent-bar
    elementType: shape
    bounds: [0, 5, 1280, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # Page title
  - elementId: toc-title
    elementType: text
    bounds: [60, 22, 480, 50]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:34px; color:#0F2647; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>目录</strong></span><span style="font-size:17px; color:#8899AA; font-family:Liter, MiSans;">  / CONTENTS</span></p>

  # Divider
  - elementId: toc-divider
    elementType: shape
    bounds: [60, 78, 1160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$border"

  # Entry 1
  - elementId: toc-num1
    elementType: text
    bounds: [60, 100, 90, 65]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:54px; color:#1B3A6B; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>01</strong></span></p>

  - elementId: toc-title1
    elementType: text
    bounds: [160, 100, 500, 30]
