      wrap: false
      text: |
        <p><span style="font-size:22px; color:#0F2647; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>行业概览与宏观环境</strong></span></p>

  - elementId: toc-desc1
    elementType: text
    bounds: [160, 135, 500, 26]
    content:
