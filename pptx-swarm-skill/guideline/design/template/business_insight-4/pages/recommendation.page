        - content:
            align: [center, middle]
            text: |
              <p><span style="font-size:13px;">40%</span></p>
        - content:
            align: [center, middle]
            text: |
              <p><span style="font-size:13px;">367元</span></p>
      - - content:
            align: [left, middle]
            text: |
              <p><span style="font-size:13px;"><strong>综合目标价</strong></span></p>
        - content:
            align: [center, middle]
            text: |
              <p><span style="font-size:13px;"><strong>100%</strong></span></p>
        - content:
            align: [center, middle]
            text: |
              <p><span style="font-size:13px; color:#37474F;"><strong>388元</strong></span></p>
      - - content:
            align: [left, middle]
            text: |
              <p><span style="font-size:13px;">较当前价上涨空间</span></p>
        - content:
            align: [center, middle]
            text: |
              <p><span style="font-size:13px;">-</span></p>
        - content:
            align: [center, middle]
            text: |
              <p><span style="font-size:13px; color:#37474F;"><strong>24.4%</strong></span></p>

  # 底部总结
  - elementId: summary-line
    elementType: shape
    bounds: [60, 540, 1160, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  - elementId: summary-text
    elementType: text
    bounds: [60, 552, 1160, 100]
    content:
      align: [left, top]
      wrap: true
      lineHeight: 1.6
      text: |
        <p><span style="font-size:18px; color:#333333; font-family:Arial, MiSans;"><strong>投资建议：</strong>我们首次覆盖比亚迪，给予"强烈推荐"评级，12个月目标价388元（+24.4%）。公司作为全球新能源汽车龙头，规模优势、垂直整合和全球化布局构成长期核心竞争壁垒。2025-2027年盈利CAGR达29.8%，当前22.8x PE处于历史估值中位数以下，具备较高安全边际。建议投资者在当前价位积极建仓，中长期配置价值突出。</span></p>

