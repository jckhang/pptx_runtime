pageType: final
background:
  type: solid
  color: "$primary"
elements:
  # 顶部accent装饰条
  - elementId: top-accent
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # 左侧lightpanel色块
  - elementId: left-block
    elementType: shape
    bounds: [0, 4, 480, 712]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  # 左侧大标题
  - elementId: final-title
    elementType: text
    bounds: [60, 200, 360, 110]
    content:
      align: [left, middle]
      wrap: true
      lineHeight: 1.3
      text: |
        <p><span style="font-size:44px; color:#ffffff; font-family:Times New Roman, SimSun, MiSans;"><strong>谢谢</strong></span></p>
        <p><span style="font-size:24px; color:#ffffff66;">Thank You</span></p>

  # 左侧accent装饰线
  - elementId: final-line
    elementType: shape
    bounds: [60, 320, 140, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 3, color: "$accent"}

  # 左侧副标题
  - elementId: final-subtitle
    elementType: text
    bounds: [60, 340, 360, 80]
    content:
      align: [left, top]
      fontSize: 18
      color: "#ffffffcc"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-family:Calibri, Microsoft YaHei, MiSans;">如需进一步讨论报告内容或探讨合作机会，请联系研究团队</span></p>

  # 左侧分类标签
  - elementId: final-classification
    elementType: text
    bounds: [60, 600, 360, 30]
    content:
      align: [left, middle]
      fontSize: 14
      color: "#ffffff66"
      wrap: false
      text: |
        <p>文件密级：机密 | 仅限内部使用</p>

  # 右侧标题
  - elementId: nextstep-title
    elementType: text
    bounds: [540, 120, 600, 35]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:22px; color:#ffffff; font-family:Times New Roman, SimSun, MiSans;"><strong>后续行动计划</strong></span></p>

  # 分隔线
  - elementId: nextstep-line
    elementType: shape
    bounds: [540, 165, 300, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$accent"}

  # 下一步行动
  - elementId: next-steps
    elementType: text
    bounds: [540, 185, 680, 265]
    content:
      fontSize: 15
      color: "$text"
      lineHeight: 1.6
      wrap: true
      text: |
        <p><span style="font-size:15px; color:#ffffff; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>1. 投资决策会议</strong></span></p>
        <p><span style="font-size:14px; color:#C0C0C0;">安排投委会专题讨论，审议报告核心结论与投资建议，预计1周内完成</span></p>
        <p style="margin-top:10px"><span style="font-size:15px; color:#ffffff; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>2. 深度尽职调查</strong></span></p>
        <p><span style="font-size:14px; color:#C0C0C0;">对重点推荐的3家标的企业启动现场调研，包括管理层访谈、供应链走访</span></p>
        <p style="margin-top:10px"><span style="font-size:15px; color:#ffffff; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>3. 组合方案制定</strong></span></p>
        <p><span style="font-size:14px; color:#C0C0C0;">基于尽调结果，制定具体仓位分配方案，包含建仓节奏与风控规则</span></p>
        <p style="margin-top:10px"><span style="font-size:15px; color:#ffffff; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>4. 定期跟踪复盘</strong></span></p>
        <p><span style="font-size:14px; color:#C0C0C0;">建立月度跟踪机制，每季度输出更新报告，动态调整投资策略</span></p>

  # 联系信息区域
  - elementId: contact-bg
    elementType: shape
    bounds: [540, 470, 680, 110]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  - elementId: contact-info
    elementType: text
    bounds: [560, 482, 640, 90]
    content:
      fontSize: 14
      color: "$text"
      lineHeight: 1.6
      wrap: true
      text: |
        <p><span style="font-size:14px; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>项目负责人：</strong>张明 | zhangming@research.com | +86 138-0000-0001</span></p>
        <p><span style="font-size:14px; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>研究团队：</strong>strategy@research.com</span></p>
        <p><span style="font-size:14px; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>报告编号：</strong>BI-2026-0324 | 版本：V1.0</span></p>

  # 底部装饰条
  - elementId: bottom-bar
    elementType: shape
    bounds: [480, 716, 800, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # 分隔线
  - elementId: bottom-accent
    elementType: shape
    bounds: [540, 610, 200, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  - elementId: copyright
    elementType: text
    bounds: [540, 620, 680, 30]
    content:
      fontSize: 12
      color: "$border"
      wrap: true
      text: |
        <p><span style="font-size:12px;">© 2026 战略研究部. 版权所有. 未经书面授权，禁止复制、分发或引用本报告内容.</span></p>
