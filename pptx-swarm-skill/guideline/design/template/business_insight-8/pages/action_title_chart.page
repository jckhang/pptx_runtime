pageType: content
background:
  type: solid
  color: "$primary"
elements:
  # 顶部accent装饰线
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # lightpanel标题带
  - elementId: title-bg
    elementType: shape
    bounds: [0, 4, 1280, 55]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  # Action Title
  - elementId: page-title
    elementType: text
    bounds: [50, 10, 1100, 46]
    content:
      align: [left, middle]
      wrap: true
      text: |
        <p><span style="font-size:20px; color:#ffffff; font-family:Times New Roman, SimSun, MiSans;"><strong>新能源汽车渗透率突破40%，传统燃油车市场份额加速萎缩已成不可逆趋势</strong></span></p>

  # 图表标题
  - elementId: chart-title
    elementType: text
    bounds: [50, 72, 500, 26]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:16px; color:#E8E8E8; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>中国新能源汽车月度销量与渗透率（2023-2025）</strong></span></p>

  # 主图表
  - elementId: main-chart
    elementType: chart
    bounds: [50, 102, 1180, 340]
    type: combo
    options:
      fontFamily: "Calibri, Microsoft YaHei, MiSans"
    data:
      - {month: "2023Q1", sales: 158, penetration: 0.262}
      - {month: "2023Q2", sales: 187, penetration: 0.286}
      - {month: "2023Q3", sales: 224, penetration: 0.318}
      - {month: "2023Q4", sales: 265, penetration: 0.342}
      - {month: "2024Q1", sales: 210, penetration: 0.335}
      - {month: "2024Q2", sales: 278, penetration: 0.378}
      - {month: "2024Q3", sales: 312, penetration: 0.405}
      - {month: "2024Q4", sales: 358, penetration: 0.428}
    x: month
    y: [sales, penetration]
    names: ["销量（万辆）", "渗透率"]
    colors: ["$accent", "$highlight"]
    seriesStyle:
      sales: {type: bar}
      penetration:
        type: line
        axis: secondary
        smooth: true
        width: 3
        fill:
          type: solid
          color: "$highlight"
        marker:
          shape: circle
          size: 6
          fill:
            type: solid
            color: "$highlight"
          border: {style: solid, width: 2, color: "$highlight"}
    legend: {position: top, fontSize: 12}
    dataLabels:
      show: true
      content: value
      fontSize: 11
    xAxis:
      label: {fontSize: 11, color: "$text"}
      gridLine: false
      axisLine: {color: "$border"}
    yAxis:
      label: {fontSize: 11, color: "$border"}
      gridLine: {color: "#1A3558", style: dash}
      axisLine: false
    secondaryAxis:
      label: {fontSize: 11, color: "$highlight"}
      numberFormat: "0%"

  # 分析区域背景
  - elementId: analysis-bg
    elementType: shape
    bounds: [50, 452, 1180, 195]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  # 分析标题
  - elementId: analysis-title
    elementType: text
    bounds: [70, 462, 300, 26]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:16px; color:#5BA4CF; font-family:Times New Roman, SimSun, MiSans;"><strong>关键分析要点</strong></span></p>

  # 分析内容 - 左列
  - elementId: analysis-col1
    elementType: text
    bounds: [70, 494, 370, 140]
    content:
      fontSize: 14
      color: "$text"
      lineHeight: 1.6
      wrap: true
      text: |
        <p><span style="font-size:14px; color:#ffffff;"><strong>供给侧驱动因素</strong></span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 电池成本下降至$100/kWh以下，整车制造成本持续优化</span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 头部车企产能扩张提速，2025年规划产能超800万辆</span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 充电基础设施覆盖率同比提升65%</span></p>

  # 分析内容 - 中列
  - elementId: analysis-col2
    elementType: text
    bounds: [460, 494, 370, 140]
    content:
      fontSize: 14
      color: "$text"
      lineHeight: 1.6
      wrap: true
      text: |
        <p><span style="font-size:14px; color:#ffffff;"><strong>需求侧变化</strong></span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 消费者接受度从2021年23%提升至2025年58%</span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 三四线城市渗透加速，增速超一线城市2倍</span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 换购需求占比从15%提升至32%</span></p>

  # 分析内容 - 右列
  - elementId: analysis-col3
    elementType: text
    bounds: [850, 494, 370, 140]
    content:
      fontSize: 14
      color: "$text"
      lineHeight: 1.6
      wrap: true
      text: |
        <p><span style="font-size:14px; color:#ffffff;"><strong>竞争格局影响</strong></span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 比亚迪市占率从18%提升至28%，龙头地位稳固</span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 合资品牌新能源转型滞后，份额持续被蚕食</span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">&#9632; 新势力分化加剧，尾部品牌面临出清</span></p>

  # 底部darkpanel footer
  - elementId: footer-bg
    elementType: shape
    bounds: [0, 660, 1280, 60]
    shapeName: rect
    fill:
      type: solid
      color: "$darkpanel"

  - elementId: source-text
    elementType: text
    bounds: [50, 668, 700, 22]
    content:
      style: "$caption"
      wrap: false
      text: |
        <p>数据来源：中汽协、乘联会月度产销数据，国家统计局</p>

  # 页码
  - elementId: page-number
    elementType: text
    bounds: [1130, 668, 100, 22]
    content:
      align: [right, middle]
      fontSize: 12
      color: "$text"
      wrap: false
      text: |
        <p>04</p>
