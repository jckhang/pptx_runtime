      align: [left, middle]
      wrap: true
      text: |
        <p><span style="font-size:20px; color:#ffffff; font-family:Times New Roman, SimSun, MiSans;"><strong>核心经营指标全面超预期，营收与利润实现双位数增长验证战略有效性</strong></span></p>

