  # 趋势图标题
  - elementId: trend-title
    elementType: text
    bounds: [50, 342, 500, 26]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:16px; color:#E8E8E8; font-family:Calibri, Microsoft YaHei, MiSans;"><strong>季度营收趋势与利润率变化</strong></span></p>

  - elementId: trend-chart
    elementType: chart
    bounds: [50, 372, 780, 260]
    type: combo
    options:
      fontFamily: "Calibri, Microsoft YaHei, MiSans"
    data:
      - {quarter: "Q1'24", revenue: 186, margin: 0.245}
      - {quarter: "Q2'24", revenue: 205, margin: 0.262}
      - {quarter: "Q3'24", revenue: 218, margin: 0.278}
      - {quarter: "Q4'24", revenue: 247, margin: 0.286}
      - {quarter: "Q1'25", revenue: 198, margin: 0.268}
      - {quarter: "Q2'25", revenue: 232, margin: 0.295}
      - {quarter: "Q3'25E", revenue: 250, margin: 0.302}
      - {quarter: "Q4'25E", revenue: 276, margin: 0.315}
    x: quarter
    y: [revenue, margin]
    names: ["营收（亿元）", "净利率"]
    colors: ["$accent", "$highlight"]
    seriesStyle:
      revenue: {type: bar}
      margin:
        type: line
        axis: secondary
        smooth: true
        width: 3
        fill:
          type: solid
          color: "$highlight"
        marker:
          shape: circle
          size: 5
          fill:
            type: solid
            color: "$highlight"
          border: {style: solid, width: 2, color: "$highlight"}
    legend: {position: top, fontSize: 11}
    dataLabels:
      show: true
      content: value
      fontSize: 10
    xAxis:
      label: {fontSize: 10, color: "$text"}
      gridLine: false
      axisLine: {color: "$border"}
    yAxis:
      label: {fontSize: 10, color: "$border"}
      gridLine: {color: "#1A3558", style: dash}
      axisLine: false
    secondaryAxis:
      label: {fontSize: 10, color: "$highlight"}
      numberFormat: "0%"

  # 右侧分析要点
  - elementId: insight-bg
