pageType: content
background:
  type: solid
  color: "$primary"
elements:
  # 顶部accent装饰线
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # lightpanel标题带
  - elementId: title-bg
    elementType: shape
    bounds: [0, 4, 1280, 55]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  # Action Title
  - elementId: page-title
    elementType: text
    bounds: [50, 10, 1100, 46]
    content:
      align: [left, middle]
      wrap: true
      text: |
        <p><span style="font-size:20px; color:#ffffff; font-family:Times New Roman, SimSun, MiSans;"><strong>投资决策五步框架：从行业筛选到组合构建的系统化方法论</strong></span></p>

  # Step 1
  - elementId: step1-box
    elementType: shape
    bounds: [50, 92, 210, 80]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: step1-label
    elementType: text
    bounds: [50, 92, 210, 80]
    content:
      align: [center, middle]
      wrap: true
      lineHeight: 1.4
      text: |
        <p><span style="font-size:13px; color:#ffffff88;">STEP 01</span></p>
        <p><span style="font-size:18px; color:#ffffff;"><strong>行业筛选</strong></span></p>

  - elementId: arrow1
    elementType: shape
    bounds: [260, 122, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$accent"}
    arrow: [null, "arrow"]

  # Step 2
  - elementId: step2-box
    elementType: shape
    bounds: [290, 92, 210, 80]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: step2-label
    elementType: text
    bounds: [290, 92, 210, 80]
    content:
      align: [center, middle]
      wrap: true
      lineHeight: 1.4
      text: |
        <p><span style="font-size:13px; color:#ffffff88;">STEP 02</span></p>
        <p><span style="font-size:18px; color:#ffffff;"><strong>企业分析</strong></span></p>

  - elementId: arrow2
    elementType: shape
    bounds: [500, 122, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$accent"}
    arrow: [null, "arrow"]

  # Step 3
  - elementId: step3-box
    elementType: shape
    bounds: [530, 92, 210, 80]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: step3-label
    elementType: text
    bounds: [530, 92, 210, 80]
    content:
      align: [center, middle]
      wrap: true
      lineHeight: 1.4
      text: |
        <p><span style="font-size:13px; color:#ffffff88;">STEP 03</span></p>
        <p><span style="font-size:18px; color:#ffffff;"><strong>估值判断</strong></span></p>

  - elementId: arrow3
    elementType: shape
    bounds: [740, 122, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$accent"}
    arrow: [null, "arrow"]

  # Step 4
  - elementId: step4-box
    elementType: shape
    bounds: [770, 92, 210, 80]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: step4-label
    elementType: text
    bounds: [770, 92, 210, 80]
    content:
      align: [center, middle]
      wrap: true
      lineHeight: 1.4
      text: |
        <p><span style="font-size:13px; color:#ffffff88;">STEP 04</span></p>
        <p><span style="font-size:18px; color:#ffffff;"><strong>风险评估</strong></span></p>

  - elementId: arrow4
    elementType: shape
    bounds: [980, 122, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$accent"}
    arrow: [null, "arrow"]

  # Step 5 (highlight golden)
  - elementId: step5-box
    elementType: shape
    bounds: [1010, 92, 220, 80]
    shapeName: rect
    fill:
      type: solid
      color: "$highlight"

  - elementId: step5-label
    elementType: text
    bounds: [1010, 92, 220, 80]
    content:
      align: [center, middle]
      wrap: true
      lineHeight: 1.4
      text: |
        <p><span style="font-size:13px; color:#0C234088;">STEP 05</span></p>
        <p><span style="font-size:18px; color:#0C2340;"><strong>组合构建</strong></span></p>

  # Step descriptions
  - elementId: desc1-bg
    elementType: shape
    bounds: [50, 187, 210, 250]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  - elementId: desc1-text
    elementType: text
    bounds: [65, 197, 180, 230]
    content:
      fontSize: 12
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:13px; color:#5BA4CF;"><strong>核心方法</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 宏观经济周期定位</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 产业政策方向梳理</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 技术变革趋势评估</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; TAM/SAM/SOM测算</span></p>
        <p style="margin-top:8px"><span style="font-size:13px; color:#5BA4CF;"><strong>产出</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">5-8个重点赛道清单，含市场规模与增速预测</span></p>

  - elementId: desc2-bg
    elementType: shape
    bounds: [290, 187, 210, 250]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  - elementId: desc2-text
    elementType: text
    bounds: [305, 197, 180, 230]
    content:
      fontSize: 12
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:13px; color:#5BA4CF;"><strong>核心方法</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 财务三表深度分析</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 竞争壁垒评估（Porter）</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 管理层能力评分</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; ESG合规性审查</span></p>
        <p style="margin-top:8px"><span style="font-size:13px; color:#5BA4CF;"><strong>产出</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">各赛道3-5家候选标的，含详细评分卡</span></p>

  - elementId: desc3-bg
    elementType: shape
    bounds: [530, 187, 210, 250]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  - elementId: desc3-text
    elementType: text
    bounds: [545, 197, 180, 230]
    content:
      fontSize: 12
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:13px; color:#5BA4CF;"><strong>核心方法</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; DCF内在价值测算</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 相对估值（PE/PB/EV）</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; PEG合理性验证</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 历史估值区间分析</span></p>
        <p style="margin-top:8px"><span style="font-size:13px; color:#5BA4CF;"><strong>产出</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">目标价区间与安全边际评估</span></p>

  - elementId: desc4-bg
    elementType: shape
    bounds: [770, 187, 210, 250]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  - elementId: desc4-text
    elementType: text
    bounds: [785, 197, 180, 230]
    content:
      fontSize: 12
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:13px; color:#5BA4CF;"><strong>核心方法</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 情景分析（乐观/中性/悲观）</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 敏感性分析</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 黑天鹅事件预案</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 流动性风险评估</span></p>
        <p style="margin-top:8px"><span style="font-size:13px; color:#5BA4CF;"><strong>产出</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">风险矩阵与对冲策略建议</span></p>

  - elementId: desc5-bg
    elementType: shape
    bounds: [1010, 187, 220, 250]
    shapeName: rect
    fill:
      type: solid
      color: "$lightpanel"

  - elementId: desc5-text
    elementType: text
    bounds: [1025, 197, 190, 230]
    content:
      fontSize: 12
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:13px; color:#E8B931;"><strong>核心方法</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 仓位分配（核心+卫星）</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 行业轮动策略</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 再平衡触发条件</span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">&#9632; 止盈止损纪律</span></p>
        <p style="margin-top:8px"><span style="font-size:13px; color:#E8B931;"><strong>产出</strong></span></p>
        <p><span style="font-size:12px; color:#C0C0C0;">投资组合方案与动态管理规则</span></p>

  # 底部核心原则
  - elementId: principle-line
    elementType: shape
    bounds: [50, 452, 1180, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  - elementId: principle-title
    elementType: text
    bounds: [50, 467, 300, 26]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:16px; color:#5BA4CF; font-family:Times New Roman, SimSun, MiSans;"><strong>核心投资原则</strong></span></p>

  - elementId: principle1
    elementType: text
    bounds: [50, 500, 380, 90]
    content:
      fontSize: 13
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:14px; color:#ffffff;"><strong>1. 确定性优先</strong></span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">优先选择商业模式已验证、现金流可预测的企业。不确定性高的标的，即使赔率诱人也需严格控制仓位（不超过5%）。</span></p>

  - elementId: principle2
    elementType: text
    bounds: [460, 500, 380, 90]
    content:
      fontSize: 13
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:14px; color:#ffffff;"><strong>2. 安全边际思维</strong></span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">要求买入价格低于内在价值20%以上。当市场情绪过热（PE>40x且PEG>2x）时，坚决不追高，耐心等待回调机会。</span></p>

  - elementId: principle3
    elementType: text
    bounds: [870, 500, 360, 90]
    content:
      fontSize: 13
      color: "$text"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:14px; color:#ffffff;"><strong>3. 动态再平衡</strong></span></p>
        <p><span style="font-size:13px; color:#C0C0C0;">每季度审视组合偏离度，当单一标的权重偏离目标超5pp或行业配置偏离超10pp时触发再平衡操作。</span></p>

  # 底部darkpanel footer
  - elementId: footer-bg
    elementType: shape
    bounds: [0, 660, 1280, 60]
    shapeName: rect
    fill:
      type: solid
      color: "$darkpanel"

  - elementId: source-text
    elementType: text
    bounds: [50, 668, 700, 22]
    content:
      style: "$caption"
      wrap: false
      text: |
        <p>数据来源：投资决策委员会方法论手册，V3.2版</p>

  - elementId: page-number
    elementType: text
    bounds: [1130, 668, 100, 22]
    content:
      align: [right, middle]
      fontSize: 12
      color: "$text"
      wrap: false
      text: |
        <p>09</p>
