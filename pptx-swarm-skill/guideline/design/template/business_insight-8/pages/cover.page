pageType: cover
background:
  type: solid
  color: "$primary"
elements:
  # 顶部accent浅蓝装饰线
  - elementId: top-accent
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # 中央大标题
  - elementId: cover-title
    elementType: text
    bounds: [140, 160, 1000, 140]
    content:
      align: [center, middle]
      wrap: true
      lineHeight: 1.3
      text: |
        <p><span style="font-size:46px; color:#ffffff; font-family:Times New Roman, SimSun, MiSans;"><strong>行业深度</strong></span></p>
        <p><span style="font-size:46px; color:#ffffff; font-family:Times New Roman, SimSun, MiSans;"><strong>研究报告</strong></span></p>

  # 副标题
  - elementId: cover-subtitle
    elementType: text
    bounds: [240, 320, 800, 40]
    content:
      align: [center, middle]
      fontSize: 20
      color: "#ffffffcc"
      text: |
        <p><span style="font-family:Calibri, Microsoft YaHei, MiSans;">商业战略与市场深度分析</span></p>

  # 中央accent装饰线
  - elementId: cover-line
    elementType: shape
    bounds: [540, 380, 200, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$accent"}

  # 核心数据点 1
  - elementId: stat1-num
    elementType: text
    bounds: [140, 420, 280, 55]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:40px; color:#E8B931; font-family:Calibri Light, Arial, MiSans;"><strong>¥2.8万亿</strong></span></p>

  - elementId: stat1-label
    elementType: text
    bounds: [140, 478, 280, 22]
    content:
      align: [center, middle]
      fontSize: 14
      color: "$border"
      wrap: false
      text: |
        <p>2025年市场总规模</p>

  # 核心数据点 2
  - elementId: stat2-num
    elementType: text
    bounds: [500, 420, 280, 55]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:40px; color:#5BA4CF; font-family:Calibri Light, Arial, MiSans;"><strong>+18.6%</strong></span></p>

  - elementId: stat2-label
    elementType: text
    bounds: [500, 478, 280, 22]
    content:
      align: [center, middle]
      fontSize: 14
      color: "$border"
      wrap: false
      text: |
        <p>同比增长率</p>

  # 核心数据点 3
  - elementId: stat3-num
    elementType: text
    bounds: [860, 420, 280, 55]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:40px; color:#5BA4CF; font-family:Calibri Light, Arial, MiSans;"><strong>CR5 62%</strong></span></p>

  - elementId: stat3-label
    elementType: text
    bounds: [860, 478, 280, 22]
    content:
      align: [center, middle]
      fontSize: 14
      color: "$border"
      wrap: false
      text: |
        <p>行业集中度</p>

  # 日期
  - elementId: cover-date
    elementType: text
    bounds: [440, 540, 400, 30]
    content:
      align: [center, middle]
      fontSize: 16
      color: "#ffffffaa"
      wrap: false
      text: |
        <p><span style="font-family:Calibri, Microsoft YaHei, MiSans;">2026年3月 | 机密文件</span></p>

  # 机构
  - elementId: cover-org
    elementType: text
    bounds: [440, 575, 400, 30]
    content:
      align: [center, middle]
      fontSize: 14
      color: "#ffffff88"
      wrap: false
      text: |
        <p><span style="font-family:Calibri, Microsoft YaHei, MiSans;">战略研究部 · 行业研究团队</span></p>

  # 底部disclaimer
  - elementId: bottom-line
    elementType: shape
    bounds: [140, 640, 1000, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  - elementId: cover-disclaimer
    elementType: text
    bounds: [140, 650, 1000, 40]
    content:
      fontSize: 12
      color: "$border"
      lineHeight: 1.4
      wrap: true
      align: [center, top]
      text: |
        <p><span style="font-size:12px;">本报告仅供内部决策参考，数据来源于公开市场资料及自有研究模型，不构成投资建议</span></p>

  # 底部accent装饰线
  - elementId: bottom-accent
    elementType: shape
    bounds: [0, 716, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
