pageType: content
background:
  type: solid
  color: "#0A0A0A"
elements:
  - elementId: arr-number
    elementType: text
    bounds: [80, 40, 600, 72]
    content:
      fontSize: 60
      color: "#10B981"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>$12.4M ARR</strong></p>

  - elementId: arr-sub
    elementType: text
    bounds: [80, 116, 400, 24]
    content:
      fontSize: 16
      color: "#A3A3A3"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p>Annual Recurring Revenue · Q4 2024</p>

  - elementId: traction-chart
    elementType: chart
    bounds: [80, 170, 1120, 400]
    type: bar
    options:
      fontFamily: "QuattrocentoSans, MiSans"
    data:
      - {quarter: "Q1'23", arr: 1.8}
      - {quarter: "Q2'23", arr: 2.4}
      - {quarter: "Q3'23", arr: 3.1}
      - {quarter: "Q4'23", arr: 3.8}
      - {quarter: "Q1'24", arr: 4.6}
      - {quarter: "Q2'24", arr: 5.8}
      - {quarter: "Q3'24", arr: 7.2}
      - {quarter: "Q4'24", arr: 12.4}
    x: quarter
    y: [arr]
    names: ["ARR ($M)"]
    colors: ["#10B981"]
    legend: false
    dataLabels:
      show: true
      content: value
      fontSize: 14
      color: "#F8FAFC"
    xAxis:
      label: {fontSize: 13, color: "#A3A3A3"}
      gridLine: false
      axisLine: false
    yAxis:
      label: false
      gridLine: false
      axisLine: false

  # Milestone markers
  - elementId: milestone-1
    elementType: text
    bounds: [80, 590, 360, 44]
    content:
      fontSize: 14
      color: "#A3A3A3"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.4
      wrap: true
      text: |
        <p><span style="color:#10B981;">&#9679;</span> Q2'23 · First $1M ARR</p>

  - elementId: milestone-2
    elementType: text
    bounds: [460, 590, 360, 44]
    content:
      fontSize: 14
      color: "#A3A3A3"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.4
      wrap: true
      text: |
        <p><span style="color:#10B981;">&#9679;</span> Q1'24 · 200+ Enterprise Clients</p>

  - elementId: milestone-3
    elementType: text
    bounds: [840, 590, 360, 44]
    content:
      fontSize: 14
      color: "#A3A3A3"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.4
      wrap: true
      text: |
        <p><span style="color:#10B981;">&#9679;</span> Q4'24 · Net Revenue Retention 128%</p>

  - elementId: page-num
    elementType: text
    bounds: [1150, 680, 50, 24]
    content:
      fontSize: 13
      color: "#A3A3A3"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: "06"
