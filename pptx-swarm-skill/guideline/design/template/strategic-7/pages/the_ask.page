pageType: content
background:
  type: solid
  color: "#0A0A0A"
elements:
  # Left side: Team
  - elementId: team-label
    elementType: text
    bounds: [80, 40, 200, 28]
    content:
      fontSize: 13
      color: "#A3A3A3"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: FOUNDING TEAM

  # Team member 1
  - elementId: team-photo-1
    elementType: shape
    bounds: [80, 100, 140, 140]
    shapeName: rect
    fill:
      type: solid
      color: "#262626"

  - elementId: team-name-1
    elementType: text
    bounds: [80, 250, 140, 24]
    content:
      fontSize: 16
      color: "#F8FAFC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>张三</strong></p>

  - elementId: team-role-1
    elementType: text
    bounds: [80, 276, 140, 48]
    content:
      fontSize: 12
      color: "#A3A3A3"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, top]
      lineHeight: 1.4
      wrap: true
      text: |
        <p>CEO · Ex-Microsoft</p>
        <p>15yr Enterprise SaaS</p>

  # Team member 2
  - elementId: team-photo-2
