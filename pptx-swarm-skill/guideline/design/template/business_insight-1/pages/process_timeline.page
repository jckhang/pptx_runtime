pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 顶部深青绿色带
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 5]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 页面标题区域背景
  - elementId: title-bg
    elementType: shape
    bounds: [0, 5, 1280, 60]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 页面标题
  - elementId: page-title
    elementType: text
    bounds: [50, 12, 1100, 40]
    content:
      fontSize: 20
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Strategic roadmap outlines four-phase transformation over 24-month horizon</strong></p>
  # ===== 时间轴主线 =====
  - elementId: timeline-line
    elementType: shape
    bounds: [100, 200, 1080, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 3, color: "$primary"}
    arrow: [null, "arrow"]

  # ===== Phase 1 =====
  - elementId: p1-dot
    elementType: shape
    bounds: [140, 190, 20, 20]
    shapeName: ellipse
    fill:
      type: solid
      color: "$primary"

  - elementId: p1-label-bg
    elementType: shape
    bounds: [90, 155, 120, 28]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: p1-label-text
    elementType: text
    bounds: [90, 155, 120, 28]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:13px; color:#ffffff;"><strong>Phase 1</strong></span></p>

  - elementId: p1-time
    elementType: text
    bounds: [90, 215, 120, 22]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:12px; color:#0D8B7D;"><strong>Q1-Q2 2024</strong></span></p>

  - elementId: p1-title
