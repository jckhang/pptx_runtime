pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # Big CONTENTS title — upper left
  - elementId: toc-title
    elementType: text
    bounds: [17, 6, 580, 200]
    content:
      style: "$pageTitle"
      align: [left, top]
      text: |
        <p>TABLE OF</p>
        <p>CONTENTS</p>

  # Chapter items
  - elementId: item-1
    elementType: text
    bounds: [31, 280, 560, 32]
    content:
      style: "$body"
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-family:Liter, MiSans; font-size:20px;">01</span>   Chapter Title One</p>

  - elementId: rule-1
    elementType: shape
    bounds: [31, 316, 560, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$gray"

  - elementId: item-2
