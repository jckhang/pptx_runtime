pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 顶部导航栏
  - elementId: nav_bg
    elementType: shape
    bounds: [0, 0, 1280, 60]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"
  
  - elementId: nav1
    elementType: text
    bounds: [0, 0, 256, 60]
    content:
      fontSize: 16
      color: "$accent"
      align: [center, middle]
      text: |
        <p><strong>年度目标完成情况</strong></p>

  - elementId: nav2
    elementType: text
    bounds: [256, 0, 256, 60]
    content:
      fontSize: 16
      color: "$light_text"
      align: [center, middle]
      text: |
        <p>核心业务增长归因</p>

  - elementId: nav3
    elementType: text
    bounds: [512, 0, 256, 60]
    content:
      fontSize: 16
      color: "$light_text"
      align: [center, middle]
      text: |
        <p>重点项目进展</p>

  - elementId: nav4
    elementType: text
    bounds: [768, 0, 256, 60]
    content:
      fontSize: 16
      color: "$light_text"
      align: [center, middle]
      text: |
        <p>竞争态势分析</p>

  - elementId: nav5
    elementType: text
    bounds: [1024, 0, 256, 60]
    content:
      fontSize: 16
      color: "$light_text"
      align: [center, middle]
      text: |
        <p>2025年计划</p>
  
  # 页面标题
  - elementId: page_title
    elementType: text
    bounds: [80, 80, 1120, 50]
    content:
      style: "$page_title"
      text: |
        <p><strong>Q4核心指标全面达成，年度目标超额完成12%</strong></p>
  
  # KPI卡片1 - 营收
  - elementId: kpi1_value
    elementType: text
    bounds: [80, 170, 260, 60]
    content:
      style: "$kpi_number"
      align: [center, middle]
      text: |
        <p>156.8<span style="font-size:24px;">亿</span></p>
  
  - elementId: kpi1_label
    elementType: text
    bounds: [80, 230, 260, 40]
    content:
      fontSize: 20
      color: "$text"
      align: [center, middle]
      text: |
        <p>全年营收 <span style="color:$success;">↑23%</span></p>
  
  # KPI卡片2 - 利润
  - elementId: kpi2_value
    elementType: text
    bounds: [370, 170, 260, 60]
    content:
      style: "$kpi_number"
      align: [center, middle]
      text: |
        <p>28.4<span style="font-size:24px;">亿</span></p>
  
  - elementId: kpi2_label
    elementType: text
    bounds: [370, 230, 260, 40]
    content:
      fontSize: 20
      color: "$text"
      align: [center, middle]
      text: |
        <p>净利润 <span style="color:$success;">↑31%</span></p>
  
  # KPI卡片3 - 客户数
  - elementId: kpi3_value
    elementType: text
    bounds: [660, 170, 260, 60]
    content:
      style: "$kpi_number"
      align: [center, middle]
      text: |
        <p>3,247</p>
  
  - elementId: kpi3_label
    elementType: text
    bounds: [660, 230, 260, 40]
    content:
      fontSize: 20
      color: "$text"
      align: [center, middle]
      text: |
        <p>企业客户数 <span style="color:$success;">↑18%</span></p>
  
  # KPI卡片4 - 留存率
  - elementId: kpi4_value
    elementType: text
    bounds: [950, 170, 260, 60]
    content:
      style: "$kpi_number"
      align: [center, middle]
      text: |
        <p>87<span style="font-size:24px;">%</span></p>
  
  - elementId: kpi4_label
    elementType: text
    bounds: [950, 230, 260, 40]
    content:
      fontSize: 20
      color: "$text"
      align: [center, middle]
      text: |
        <p>客户留存率 <span style="color:$success;">↑5pp</span></p>
  
  # 分隔线
  - elementId: divider
    elementType: shape
    bounds: [80, 290, 1120, 1]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$secondary"
  
  # 趋势图表
  - elementId: trend_chart
    elementType: chart
    bounds: [80, 330, 1120, 280]
    type: line
    data:
      - {quarter: "Q1", revenue: 32.5, profit: 5.2, target: 35}
      - {quarter: "Q2", revenue: 38.2, profit: 6.8, target: 37}
      - {quarter: "Q3", revenue: 41.6, profit: 7.9, target: 39}
      - {quarter: "Q4", revenue: 44.5, profit: 8.5, target: 41}
    x: quarter
    y: [revenue, profit, target]
    names: ["实际营收", "净利润", "目标营收"]
    colors: ["$accent", "$success", "$light_text"]
    options:
      nullHandling: connect
      fontFamily: "Liter, MiSans"
    seriesStyle:
      "*":
        smooth: true
        width: 2
      revenue:
        width: 3
      target:
        line: dash
        marker: false
    xAxis:
      label:
        color: "$light_text"
        fontSize: 14
      axisLine:
        color: "$secondary"
      gridLine: false
    yAxis:
      label:
        color: "$light_text"
        fontSize: 14
      gridLine:
        style: dot
        color: "$secondary"
      title:
        text: "金额（亿元）"
        color: "$light_text"
        fontSize: 14
    dataLabels:
      show: true
      fontSize: 12
      color: "$text"
  
  # 数据来源
  - elementId: source
    elementType: text
    bounds: [80, 630, 500, 30]
    content:
      style: "$footnote"
      text: |
        <p>Source: 2024年Q4财务看板，数据截至12月20日</p>