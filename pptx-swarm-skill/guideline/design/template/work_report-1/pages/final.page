pageType: final
background:
  type: solid
  color: "$background"
elements:
  # Q&A文字
  - elementId: qa_text
    elementType: text
    bounds: [0, 240, 1280, 100]
    content:
      fontSize: 56
      color: "$primary"
      align: [center, middle]
      text: |
        <p>Q&A</p>

  # 感谢文字
  - elementId: thanks_text
    elementType: text
    bounds: [0, 360, 1280, 60]
    content:
      fontSize: 36
      color: "$text"
      align: [center, middle]
      text: |
        <p>感谢聆听</p>

  # 联系方式
  - elementId: contact
    elementType: text
    bounds: [0, 440, 1280, 40]
    content:
      fontSize: 22
      color: "$light_text"
      align: [center, middle]
      text: |
        <p>xxx@company.com</p>
