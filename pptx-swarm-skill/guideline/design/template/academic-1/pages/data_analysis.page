    elementType: table
    bounds: [80, 110, 1120, 260]
    style: "$default"
    columnWidths: [0.30, 0.14, 0.14, 0.14, 0.14, 0.14]
    rowHeights: [0.167, 0.167, 0.167, 0.167, 0.167, 0.167]
    rows:
      - - content:
            text: |
              <p><strong>Model Variant</strong></p>
        - content:
            text: |
              <p><strong>HIV</strong></p>
        - content:
            text: |
              <p><strong>BBBP</strong></p>
        - content:
            text: |
              <p><strong>Tox21</strong></p>
        - content:
            text: |
              <p><strong>ESOL</strong></p>
        - content:
            text: |
              <p><strong>Avg.</strong></p>
      - - content:
            text: "MolGNN (Full)"
        - content:
            text: |
              <p><strong>0.821</strong></p>
        - content:
            text: |
              <p><strong>0.931</strong></p>
        - content:
            text: |
              <p><strong>0.863</strong></p>
        - content:
            text: |
              <p><strong>0.542</strong></p>
        - content:
            text: |
              <p><strong>0.842</strong></p>
      - - content:
            text: "  w/o Attention Readout"
        - content:
