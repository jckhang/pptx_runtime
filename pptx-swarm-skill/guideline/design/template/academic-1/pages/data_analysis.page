pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 顶部细线
  - elementId: top-line
    elementType: shape
    bounds: [0, 0, 1280, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 4
      color: "$primary"

  - elementId: section-marker
    elementType: text
    bounds: [80, 20, 200, 20]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: "CHAPTER 04 — 实验结果与讨论"

  - elementId: page-title
    elementType: text
    bounds: [80, 50, 800, 35]
    content:
      style: "$pageTitle"
      wrap: false
      text: |
        <p><strong>4.2 消融实验与超参数分析</strong></p>

  - elementId: title-line
    elementType: shape
    bounds: [80, 90, 1120, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#CFD8DC"

  # 消融实验表格
