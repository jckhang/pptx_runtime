        - content:
            text: "0.613"
        - content:
            text: "0.810"
      - - content:
            text: "  w/o GRU Update"
        - content:
            text: "0.803"
        - content:
            text: "0.918"
        - content:
            text: "0.848"
        - content:
            text: "0.571"
        - content:
