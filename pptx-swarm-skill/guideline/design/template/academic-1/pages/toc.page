pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 顶部细线
  - elementId: toc-top-line
    elementType: shape
    bounds: [0, 0, 1280, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 4
      color: "$primary"

  # 目录标题
  - elementId: toc-title
    elementType: text
    bounds: [80, 50, 200, 45]
    content:
      fontSize: 32
      color: "$darkGray"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>目录</strong></p>

  - elementId: toc-title-en
    elementType: text
    bounds: [80, 95, 200, 22]
    content:
      fontSize: 14
      color: "$accent"
      fontFamily: "QuattrocentoSans, MiSans"
      letterSpacing: 2
      wrap: false
      text: CONTENTS

  - elementId: toc-divider
    elementType: shape
    bounds: [80, 130, 1120, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$accent"

  # 目录项 - 简洁线性列表
  - elementId: toc-item-1-num
    elementType: text
    bounds: [80, 160, 64, 50]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>01</strong></p>

