pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 页面标题
  - elementId: toc-title
    elementType: text
    bounds: [80, 50, 400, 40]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:28px; color:#263238; font-family:SortsMillGoudy, MiSans;"><strong>目录</strong></span></p>

  # 标题下方细线
