      wrap: true
      text: |
        <p><span style="font-size:15px; color:#37474F; font-family:Liter, MiSans;"><strong>核心判断：</strong>行业已进入淘汰赛阶段，2025-2026年尾部品牌加速退出，资源向比亚迪、吉利、理想等头部企业集中。</span></p>

