pageType: chapter
background:
  type: solid
  color: "$secondary"
elements:
  # 章节编号
  - elementId: chapter-num
    elementType: text
    bounds: [80, 240, 200, 60]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:48px; color:#78909C; font-family:SortsMillGoudy, MiSans;"><strong>01</strong></span></p>

  # 章节标题
  - elementId: chapter-title
    elementType: text
    bounds: [80, 310, 1000, 60]
    content:
      align: [left, middle]
      wrap: true
      lineHeight: 1.3
      text: |
        <p><span style="font-size:36px; color:#FFFFFF; font-family:SortsMillGoudy, MiSans;"><strong>行业趋势</strong></span></p>

  # 章节副标题
  - elementId: chapter-subtitle
    elementType: text
    bounds: [80, 380, 800, 36]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:20px; color:#78909C; font-family:Liter, MiSans;">全球新能源汽车市场格局与增长驱动因素</span></p>

  # 装饰细线
  - elementId: chapter-line
    elementType: shape
    bounds: [80, 430, 160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "#78909C"
