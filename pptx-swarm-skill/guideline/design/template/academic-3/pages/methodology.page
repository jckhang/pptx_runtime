pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: content-left-line
    elementType: shape
    bounds: [0, 0, 6, 720]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: content-top-line
    elementType: shape
    bounds: [0, 0, 1280, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: content-section-name
    elementType: text
    bounds: [900, 16, 340, 22]
    content:
      fontSize: 12
      color: "$secondary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: 03 研究方法与实验设计

  - elementId: page-title
    elementType: text
    bounds: [40, 24, 840, 36]
    content:
      fontSize: 26
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>研究方法论框架与实验流程</strong></p>

  - elementId: title-separator
    elementType: shape
    bounds: [40, 68, 1200, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$borderGray"

  # 流程步骤1
  - elementId: step-1-bg
    elementType: shape
    bounds: [40, 88, 220, 380]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "$primary"

  - elementId: step-1-num
    elementType: text
    bounds: [40, 100, 220, 50]
    content:
      fontSize: 32
      color: "#FFFFFF50"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, top]
      wrap: false
      text: |
        <p>01</p>

  - elementId: step-1-title
    elementType: text
    bounds: [50, 160, 200, 24]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: true
      text: |
        <p><strong>数据收集与预处理</strong></p>

  - elementId: step-1-content
    elementType: text
    bounds: [52, 196, 196, 250]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      lineHeight: 1.7
      text: |
        <p>• 原始数据清洗</p>
        <p>• 标准化与归一化</p>
        <p>• 数据增强策略</p>
        <p>• 训练/验证/测试集划分</p>
        <p>• 类别平衡采样</p>
        <p>• 特征工程与选择</p>

  # 步骤箭头1
  - elementId: arrow-1
    elementType: shape
    bounds: [268, 268, 36, 20]
    shapeName: rightArrow
    adjustments: [50000, 50000]
    fill:
      type: solid
      color: "$secondary"

  # 流程步骤2
  - elementId: step-2-bg
    elementType: shape
    bounds: [312, 88, 220, 380]
