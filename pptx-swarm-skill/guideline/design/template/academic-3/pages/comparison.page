pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 左侧细竖线
  - elementId: content-left-line
    elementType: shape
    bounds: [0, 0, 6, 720]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 顶部细蓝线
  - elementId: content-top-line
    elementType: shape
    bounds: [0, 0, 1280, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 章节名右上角
  - elementId: content-section-name
    elementType: text
    bounds: [900, 16, 340, 22]
    content:
      fontSize: 12
      color: "$secondary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: 04 实验结果与数据分析

  # 页面标题
  - elementId: page-title
    elementType: text
    bounds: [40, 24, 840, 36]
    content:
      fontSize: 26
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>与现有方法的对比实验结果</strong></p>

  - elementId: title-separator
    elementType: shape
    bounds: [40, 68, 1200, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$borderGray"

  # 图表区域（左侧60%）
  - elementId: chart-area
    elementType: shape
    bounds: [40, 84, 740, 420]
    shapeName: roundRect
    adjustments: [3000]
    fill:
      type: solid
      color: "$lightGray"

  - elementId: chart-label
    elementType: text
    bounds: [40, 84, 740, 420]
    content:
      fontSize: 14
      color: "#AAAAAA"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>Table 1. 多方法对比实验结果（五个数据集）</p>

  # 图表说明（右侧）
  - elementId: chart-insight-title
    elementType: text
    bounds: [810, 90, 420, 28]
    content:
      fontSize: 18
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>关键发现</strong></p>

  - elementId: chart-insight-sep
    elementType: shape
    bounds: [810, 122, 200, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: insight-1-bg
    elementType: shape
    bounds: [810, 138, 420, 70]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "$lightGray"

  - elementId: insight-1
    elementType: text
    bounds: [826, 148, 388, 50]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      text: |
        <p>本方法在所有数据集上均达到最优性能</p>

  - elementId: insight-2-bg
    elementType: shape
    bounds: [810, 220, 420, 70]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "$lightGray"

  - elementId: insight-2
    elementType: text
    bounds: [826, 230, 388, 50]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      text: |
        <p>平均Accuracy提升 +4.6%，F1提升 +3.9%</p>

  - elementId: insight-3-bg
    elementType: shape
    bounds: [810, 302, 420, 70]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "$lightGray"

  - elementId: insight-3
    elementType: text
    bounds: [826, 312, 388, 50]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      text: |
        <p>计算复杂度与第二名相当，效率优势显著</p>

  - elementId: insight-4-bg
    elementType: shape
    bounds: [810, 384, 420, 70]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "#E3F0FA"

  - elementId: insight-4
    elementType: text
    bounds: [826, 394, 388, 50]
    content:
      fontSize: 16
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      text: |
        <p><strong>统计检验 p &lt; 0.001，结果显著</strong></p>

  # 底部脚注
  - elementId: footnote
    elementType: text
    bounds: [40, 530, 1200, 22]
    content:
      fontSize: 12
      color: "#AAAAAA"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: 注：所有实验均在相同硬件环境下运行，每个实验重复5次取均值，括号内为标准差。

  # 页码
  - elementId: page-num
    elementType: text
    bounds: [1200, 680, 50, 24]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: "7"
