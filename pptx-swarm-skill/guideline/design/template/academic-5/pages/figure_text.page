pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 顶部导航条（各章节标题均匀分布）
  - elementId: nav-bg
    elementType: shape
    bounds: [0, 0, 1280, 44]
    shapeName: rect
    fill:
      type: solid
      color: "$navBg"

  - elementId: nav-active
    elementType: shape
    bounds: [512, 0, 256, 44]
    shapeName: rect
    fill:
      type: solid
      color: "$white"

  - elementId: nav-ch1
    elementType: text
    bounds: [0, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 01 研究背景

  - elementId: nav-div1
    elementType: shape
    bounds: [256, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch2
    elementType: text
    bounds: [256, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 02 文献综述

  - elementId: nav-div2
    elementType: shape
    bounds: [512, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch3
    elementType: text
    bounds: [512, 0, 256, 44]
    content:
      fontSize: 13
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 03 研究方法

  - elementId: nav-div3
    elementType: shape
    bounds: [768, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch4
    elementType: text
    bounds: [768, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 04 实验结果

  - elementId: nav-div4
    elementType: shape
    bounds: [1024, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch5
    elementType: text
    bounds: [1024, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 05 结论展望

  # 标题
  - elementId: title-deco-line
    elementType: shape
    bounds: [50, 62, 0, 36]
    shapeName: straightConnector1
    border:
      style: solid
      width: 4
      color: "$primary"

  - elementId: page-title
    elementType: text
    bounds: [68, 60, 900, 40]
    content:
      style: "$pageTitle"
      wrap: false
      text: |
        <p><strong>研究方法框架与流程设计</strong></p>

  - elementId: title-gold-line
    elementType: shape
    bounds: [50, 108, 1180, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#B8860B60"

  # 左侧图表占位区
  - elementId: figure-area
    elementType: shape
    bounds: [50, 120, 620, 480]
    shapeName: rect
    fill:
      type: solid
      color: "$lightRed"
    border:
      style: solid
      width: 1
      color: "#8B1A1A40"

  - elementId: figure-label
    elementType: text
    bounds: [50, 120, 620, 480]
    content:
      fontSize: 14
      color: "#8B1A1A80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>Figure 1. 研究方法整体框架图</p>

  # 右侧文字解读
  - elementId: text-section-title
    elementType: text
    bounds: [700, 124, 530, 30]
    content:
      fontSize: 18
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>方法框架说明</strong></p>

  - elementId: text-deco-line
    elementType: shape
    bounds: [700, 158, 200, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "$gold"

  - elementId: text-content-1
    elementType: text
    bounds: [700, 172, 530, 80]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      lineHeight: 1.7
      text: |
        <p><strong>数据预处理阶段：</strong>对原始数据进行清洗、标准化处理，并通过数据增强策略缓解样本不均衡问题。</p>

  - elementId: text-content-2
    elementType: text
    bounds: [700, 272, 530, 80]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      lineHeight: 1.7
      text: |
        <p><strong>模型训练阶段：</strong>采用端到端训练策略，引入对比学习机制以提升特征表达的判别能力。</p>

  - elementId: text-content-3
    elementType: text
    bounds: [700, 372, 530, 80]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      lineHeight: 1.7
      text: |
        <p><strong>评估验证阶段：</strong>使用多个基准数据集进行定量评估，同时设计消融实验验证各模块贡献。</p>

  - elementId: text-conclusion-box
    elementType: shape
    bounds: [700, 470, 530, 52]
    shapeName: rect
    fill:
      type: solid
      color: "#FFF8E6"
    border:
      style: solid
      width: 1
      color: "$gold"

  - elementId: text-conclusion
    elementType: text
    bounds: [716, 470, 498, 52]
    content:
      fontSize: 14
      color: "#6D4C00"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: true
      text: |
        <p>注：完整代码及数据集已开源，详见附录A。</p>

  # 底部金线
  - elementId: bottom-gold-line
    elementType: shape
    bounds: [0, 706, 1280, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "#B8860B"
