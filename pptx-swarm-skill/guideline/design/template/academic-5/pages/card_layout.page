pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 顶部导航条（各章节标题均匀分布）
  - elementId: nav-bg
    elementType: shape
    bounds: [0, 0, 1280, 44]
    shapeName: rect
    fill:
      type: solid
      color: "$navBg"

  - elementId: nav-active
    elementType: shape
    bounds: [1024, 0, 256, 44]
    shapeName: rect
    fill:
      type: solid
      color: "$white"

  - elementId: nav-ch1
    elementType: text
    bounds: [0, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 01 研究背景

  - elementId: nav-div1
    elementType: shape
    bounds: [256, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch2
    elementType: text
    bounds: [256, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 02 文献综述

  - elementId: nav-div2
    elementType: shape
    bounds: [512, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch3
    elementType: text
    bounds: [512, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 03 研究方法

  - elementId: nav-div3
    elementType: shape
    bounds: [768, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch4
    elementType: text
    bounds: [768, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 04 实验结果

  - elementId: nav-div4
    elementType: shape
    bounds: [1024, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch5
    elementType: text
    bounds: [1024, 0, 256, 44]
    content:
      fontSize: 13
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 05 结论展望

  # 标题
  - elementId: title-deco-line
    elementType: shape
    bounds: [50, 62, 0, 36]
    shapeName: straightConnector1
    border:
      style: solid
      width: 4
      color: "$primary"

  - elementId: page-title
    elementType: text
    bounds: [68, 60, 900, 40]
    content:
      style: "$pageTitle"
      wrap: false
      text: |
        <p><strong>本研究主要贡献与创新点</strong></p>

  - elementId: title-gold-line
    elementType: shape
    bounds: [50, 108, 1180, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#B8860B60"

  # 贡献卡片 1（上左）
  - elementId: card-1-bg
    elementType: shape
    bounds: [50, 124, 570, 220]
    shapeName: rect
    fill:
      type: solid
      color: "$lightRed"
    border:
      style: solid
      width: 2
      color: "$primary"

  - elementId: card-1-num
    elementType: shape
    bounds: [50, 124, 52, 52]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: card-1-num-text
    elementType: text
    bounds: [50, 124, 52, 52]
    content:
      fontSize: 24
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>01</strong></p>

  - elementId: card-1-title
    elementType: text
    bounds: [116, 132, 480, 28]
    content:
      fontSize: 18
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>创新方法提出</strong></p>

  - elementId: card-1-content
    elementType: text
    bounds: [66, 182, 534, 140]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      lineHeight: 1.7
      text: |
        <p>首次提出了XX方法，通过引入YY机制有效解决了ZZ问题，在理论层面填补了该领域的空白。</p>

