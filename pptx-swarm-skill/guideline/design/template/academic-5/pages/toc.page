  - elementId: toc-sep-4
    elementType: shape
    bounds: [400, 406, 840, 1]
    shapeName: rect
    fill:
      type: solid
      color: "#E0F4FA"

  - elementId: toc-diamond-5
    elementType: shape
    bounds: [414, 432, 14, 14]
    shapeName: diamond
    fill:
      type: solid
      color: "$primary"

  - elementId: toc-item-5
    elementType: text
    bounds: [440, 422, 700, 28]
    content:
      fontSize: 24
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>结论与研究展望</strong></p>

  - elementId: toc-item-5-en
    elementType: text
    bounds: [440, 453, 700, 20]
    content:
      fontSize: 14
      color: "$grayBlue"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: Conclusions and Future Work

  # 页码
  - elementId: toc-page-num
    elementType: text
    bounds: [1200, 680, 50, 24]
    content:
      fontSize: 14
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: "2"
