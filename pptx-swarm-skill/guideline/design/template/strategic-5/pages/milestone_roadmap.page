pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 52px 午夜蓝页眉条
  - elementId: header-bar
    elementType: shape
    bounds: [0, 0, 1280, 52]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: page-title
    elementType: text
    bounds: [64, 10, 1050, 32]
    content:
      fontSize: 22
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>三年里程碑路线图：2025–2028 关键节点与投资回报</strong></p>

  - elementId: page-num
    elementType: text
    bounds: [1190, 10, 60, 32]
    content:
      fontSize: 13
      color: "#FFFFFF88"
      fontFamily: "Inter, MiSans"
      align: [right, middle]
      wrap: false
      text: "08"

  # ===== 时间轴主线（3px午夜蓝） =====
  - elementId: timeline-main
    elementType: shape
    bounds: [100, 230, 1080, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 3
      color: "$primary"
    arrow: [null, "arrow"]

  # ===== 年份标记：方形16x16 =====
  # 2025
  - elementId: year1-marker
    elementType: shape
    bounds: [190, 222, 16, 16]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: year1-label
    elementType: text
    bounds: [160, 196, 76, 22]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Georgia, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>2025</strong></p>

  # 2026
  - elementId: year2-marker
    elementType: shape
    bounds: [460, 222, 16, 16]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: year2-label
    elementType: text
    bounds: [430, 196, 76, 22]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Georgia, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>2026</strong></p>

  # 2027
