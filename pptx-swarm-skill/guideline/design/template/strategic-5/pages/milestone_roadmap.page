  # ===== 关键里程碑：铜色菱形标记（在时间轴上方） =====
  - elementId: milestone1
    elementType: text
    bounds: [230, 100, 200, 20]
    content:
      fontSize: 13
      color: "$accent"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
