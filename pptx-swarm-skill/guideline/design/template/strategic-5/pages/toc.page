    fill:
      type: solid
      color: "$cardBg"

  - elementId: toc-card1-topbar
    elementType: shape
    bounds: [64, 80, 564, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: toc-card1-num
    elementType: text
    bounds: [80, 94, 60, 36]
    content:
      fontSize: 28
      color: "$accent"
      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>01</strong></p>

  - elementId: toc-card1-title
