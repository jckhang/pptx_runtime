pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 52px 午夜蓝页眉条
  - elementId: toc-header-bar
    elementType: shape
    bounds: [0, 0, 1280, 52]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: toc-header-title
    elementType: text
    bounds: [64, 10, 400, 32]
    content:
      fontSize: 22
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>目录 CONTENTS</strong></p>

  # ===== 2x4 网格卡片 =====
  # 卡片 1
  - elementId: toc-card1-bg
    elementType: shape
    bounds: [64, 80, 564, 130]
