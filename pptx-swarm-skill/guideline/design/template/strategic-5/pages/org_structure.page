      color: "$secondary"

  - elementId: vp3-text
    elementType: text
    bounds: [920, 206, 280, 40]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>财务与风控 CFO</strong></p>

  # ===== VP到Team连接线 =====
  - elementId: line-t1-down
    elementType: shape
    bounds: [220, 252, 0, 28]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$warmGray"

  - elementId: line-t2-down
    elementType: shape
    bounds: [538, 252, 0, 28]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$warmGray"

  - elementId: line-t3-down
    elementType: shape
    bounds: [742, 252, 0, 28]
