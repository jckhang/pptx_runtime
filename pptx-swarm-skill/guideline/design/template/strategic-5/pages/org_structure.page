pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 52px 午夜蓝页眉条
  - elementId: header-bar
    elementType: shape
    bounds: [0, 0, 1280, 52]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: page-title
    elementType: text
    bounds: [64, 10, 1050, 32]
    content:
      fontSize: 22
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>组织架构升级：面向全球化的治理体系重塑</strong></p>

  - elementId: page-num
    elementType: text
    bounds: [1190, 10, 60, 32]
    content:
      fontSize: 13
      color: "#FFFFFF88"
      fontFamily: "Inter, MiSans"
      align: [right, middle]
      wrap: false
      text: "06"

  # ===== CEO 顶层 =====
  - elementId: ceo-bg
    elementType: shape
    bounds: [490, 84, 300, 60]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: ceo-copper-bar
    elementType: shape
    bounds: [490, 144, 300, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: ceo-text
    elementType: text
    bounds: [490, 90, 300, 48]
    content:
      fontSize: 18
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>集团CEO / 董事长</strong></p>

  # ===== CEO到VP连接线 =====
  - elementId: line-ceo-down
    elementType: shape
    bounds: [640, 147, 0, 33]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$warmGray"

  - elementId: line-vp-horizontal
    elementType: shape
    bounds: [220, 180, 840, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$warmGray"

  - elementId: line-vp1-down
    elementType: shape
    bounds: [220, 180, 0, 20]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$warmGray"

  - elementId: line-vp2-down
    elementType: shape
    bounds: [640, 180, 0, 20]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$warmGray"

  - elementId: line-vp3-down
    elementType: shape
    bounds: [1060, 180, 0, 20]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$warmGray"

  # ===== VP层（3个） =====
  # VP 1
  - elementId: vp1-bg
    elementType: shape
    bounds: [80, 200, 280, 52]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: vp1-text
    elementType: text
    bounds: [80, 206, 280, 40]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>战略与投资 EVP</strong></p>

  # VP 2
  - elementId: vp2-bg
    elementType: shape
    bounds: [500, 200, 280, 52]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: vp2-text
    elementType: text
    bounds: [500, 206, 280, 40]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>运营与技术 COO/CTO</strong></p>

  # VP 3
  - elementId: vp3-bg
    elementType: shape
    bounds: [920, 200, 280, 52]
