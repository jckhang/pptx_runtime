    border:
      style: solid
      width: 1
      color: "$warmGray"

  # ===== Team层（5个） =====
  # Team 1
  - elementId: team1-bg
    elementType: shape
    bounds: [64, 280, 220, 120]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"

  - elementId: team1-title
    elementType: text
    bounds: [74, 288, 200, 24]
    content:
      fontSize: 15
      color: "$text"
      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>战略规划部</strong></p>

  - elementId: team1-desc
    elementType: text
    bounds: [74, 316, 200, 70]
    content:
      fontSize: 13
      color: "$warmGray"
      fontFamily: "Inter, MiSans"
      lineHeight: 1.5
      wrap: true
      text: |
        <p>&#9632; 市场研究与洞察</p>
        <p>&#9632; 战略规划与执行</p>
        <p>&#9632; 竞争情报分析</p>

  # Team 2（新增岗位，铜色边框）
