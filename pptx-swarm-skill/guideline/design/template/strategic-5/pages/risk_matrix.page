pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 52px 午夜蓝页眉条
  - elementId: header-bar
    elementType: shape
    bounds: [0, 0, 1280, 52]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: page-title
    elementType: text
    bounds: [64, 10, 1050, 32]
    content:
      fontSize: 22
      color: "$white"
      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>风险矩阵与应对策略：五大核心风险管控</strong></p>

  - elementId: page-num
    elementType: text
    bounds: [1190, 10, 60, 32]
    content:
      fontSize: 13
      color: "#FFFFFF88"
      fontFamily: "Inter, MiSans"
      align: [right, middle]
      wrap: false
      text: "07"

  # ===== 左侧55%：风险矩阵网格 =====
  # Y轴标题
  - elementId: yaxis-label
    elementType: text
    bounds: [64, 280, 20, 180]
    content:
      fontSize: 13
      color: "$text"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
      text: "影响程度 →"

  # X轴标题
  - elementId: xaxis-label
    elementType: text
    bounds: [250, 570, 200, 20]
    content:
      fontSize: 13
      color: "$text"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
      text: "发生概率 →"

  # 四象限背景
  # 左下：低概率低影响（浅绿）
  - elementId: quad-ll
    elementType: shape
    bounds: [100, 360, 260, 200]
    shapeName: rect
    fill:
      type: solid
      color: "#E8F5E9"

  # 右下：高概率低影响（浅黄）
  - elementId: quad-rl
    elementType: shape
    bounds: [360, 360, 260, 200]
    shapeName: rect
    fill:
      type: solid
      color: "#FFF8E1"

  # 左上：低概率高影响（浅红）
  - elementId: quad-lh
    elementType: shape
    bounds: [100, 160, 260, 200]
    shapeName: rect
    fill:
      type: solid
      color: "#FFF3E0"

  # 右上：高概率高影响（深红）
  - elementId: quad-rh
    elementType: shape
    bounds: [360, 160, 260, 200]
    shapeName: rect
    fill:
      type: solid
      color: "#FFEBEE"

  # 象限标签
  - elementId: quad-ll-label
    elementType: text
    bounds: [160, 520, 140, 20]
    content:
      fontSize: 11
      color: "#4CAF50"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
      text: "低风险 · 监控"

  - elementId: quad-rl-label
    elementType: text
    bounds: [420, 520, 140, 20]
    content:
      fontSize: 11
      color: "#FF9800"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
      text: "中风险 · 关注"

  - elementId: quad-lh-label
    elementType: text
    bounds: [160, 165, 140, 20]
    content:
      fontSize: 11
      color: "#FF5722"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
      text: "高风险 · 预案"

  - elementId: quad-rh-label
    elementType: text
    bounds: [420, 165, 140, 20]
    content:
      fontSize: 11
      color: "#D32F2F"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
      text: "极高风险 · 立即行动"

  # 风险点 R1（右上：地缘政治）
  - elementId: risk-dot-1
    elementType: shape
    bounds: [420, 210, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: risk-label-1
    elementType: text
    bounds: [454, 212, 100, 24]
    content:
      fontSize: 12
      color: "$text"
      fontFamily: "Inter, MiSans"
      wrap: false
      text: "R1 地缘政治"

  # 风险点 R2（右上：汇率波动）
  - elementId: risk-dot-2
    elementType: shape
    bounds: [500, 260, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: risk-label-2
    elementType: text
    bounds: [534, 262, 100, 24]
    content:
      fontSize: 12
      color: "$text"
      fontFamily: "Inter, MiSans"
      wrap: false
      text: "R2 汇率波动"

  # 风险点 R3（左上：技术颠覆）
  - elementId: risk-dot-3
    elementType: shape
    bounds: [200, 230, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "$secondary"

  - elementId: risk-label-3
    elementType: text
    bounds: [234, 232, 100, 24]
    content:
      fontSize: 12
      color: "$text"
      fontFamily: "Inter, MiSans"
      wrap: false
      text: "R3 技术颠覆"

  # 风险点 R4（右下：人才流失）
  - elementId: risk-dot-4
    elementType: shape
    bounds: [440, 420, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "$secondary"

  - elementId: risk-label-4
    elementType: text
    bounds: [474, 422, 100, 24]
    content:
      fontSize: 12
      color: "$text"
      fontFamily: "Inter, MiSans"
      wrap: false
      text: "R4 人才流失"

  # 风险点 R5（左下：监管合规）
  - elementId: risk-dot-5
    elementType: shape
    bounds: [200, 400, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "#4CAF50"

  - elementId: risk-label-5
    elementType: text
    bounds: [234, 402, 100, 24]
    content:
      fontSize: 12
      color: "$text"
      fontFamily: "Inter, MiSans"
      wrap: false
      text: "R5 监管合规"

  # ===== 右侧45%：风险应对清单 =====
  # 风险 1
  - elementId: resp-num1
    elementType: shape
    bounds: [660, 80, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: resp-num1-text
    elementType: text
    bounds: [660, 80, 28, 28]
    content:
      fontSize: 14
      color: "$white"
      fontFamily: "Inter, MiSans"
      align: [center, middle]
      wrap: false
      text: "1"

  - elementId: resp-title1
    elementType: text
    bounds: [700, 80, 516, 24]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>地缘政治风险</strong></p>

  - elementId: resp-desc1
    elementType: text
    bounds: [700, 106, 516, 44]
    content:
      fontSize: 14
      color: "$text"
      fontFamily: "Inter, MiSans"
      lineHeight: 1.5
      wrap: true
      text: |
        <p>应对：供应链多元化布局，建立区域化生产基地</p>
        <p style="font-size:12px; color:#8B8C89;">责任人：EVP战略与投资 · 优先级：P0</p>

  # 风险 2
  - elementId: resp-num2
    elementType: shape
    bounds: [660, 168, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: resp-num2-text
