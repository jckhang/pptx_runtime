      fontFamily: "Inter, MiSans"
      lineHeight: 1.5
      wrap: true
      text: |
        <p>应对：远期外汇锁定+自然对冲（本地化收支匹配）</p>
        <p style="font-size:12px; color:#8B8C89;">责任人：CFO · 优先级：P0</p>

  # 风险 3
  - elementId: resp-num3
    elementType: shape
    bounds: [660, 256, 28, 28]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: resp-num3-text
    elementType: text
    bounds: [660, 256, 28, 28]
    content:
      fontSize: 14
      color: "$white"
