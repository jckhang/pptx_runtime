      fontFamily: "Georgia, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>核心人才流失风险</strong></p>

  - elementId: resp-desc4
    elementType: text
    bounds: [700, 370, 516, 44]
    content:
      fontSize: 14
      color: "$text"
      fontFamily: "Inter, MiSans"
      lineHeight: 1.5
      wrap: true
      text: |
        <p>应对：实施长期股权激励计划+全球人才竞争力薪酬体系</p>
        <p style="font-size:12px; color:#8B8C89;">责任人：CHRO · 优先级：P1</p>

  # 风险 5
  - elementId: resp-num5
    elementType: shape
    bounds: [660, 432, 28, 28]
    shapeName: ellipse
