pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 页面标题
  - elementId: page-title
    elementType: text
    bounds: [100, 80, 400, 60]
    content:
      style: "$title"
      align: [left, middle]
      text: |
        <p><strong>目录</strong></p>

  # 右侧装饰
  - elementId: right-decoration
    elementType: shape
    bounds: [800, 100, 380, 500]
    shapeName: custom
    path: "380,500;M380 0 L380 500 L190 500 Q140 500 90 450 L90 50 Q90 0 140 0 Z"
    fill:
      type: gradient
      gradientType: linear
      angle: 180
      stops:
        - {position: 0, color: "#D0E0E310"}
        - {position: 0.7, color: "$gradient"}
        - {position: 1, color: "#2E5E8A15"}
    opacity: 0.4

  # 目录项1
  - elementId: toc-num-1
    elementType: shape
    bounds: [120, 200, 40, 40]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: toc-text-1
    elementType: text
    bounds: [120, 195, 40, 50]
    content:
      align: [center, middle]
      fontSize: 20
      color: "#FFFFFF"
      text: "01"

  - elementId: toc-content-1
    elementType: text
    bounds: [180, 200, 400, 40]
    content:
      style: "$bodyLarge"
      align: [left, middle]
      text: |
        <p>茶的起源与早期历史</p>

  # 目录项2
  - elementId: toc-num-2
    elementType: shape
    bounds: [120, 270, 40, 40]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: toc-text-2
    elementType: text
    bounds: [120, 265, 40, 50]
    content:
      align: [center, middle]
      fontSize: 20
      color: "#FFFFFF"
      text: "02"

  - elementId: toc-content-2
    elementType: text
    bounds: [180, 270, 400, 40]
    content:
      style: "$bodyLarge"
      align: [left, middle]
      text: |
        <p>丝绸之路与茶叶传播</p>

  # 目录项3
  - elementId: toc-num-3
    elementType: shape
    bounds: [120, 340, 40, 40]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: toc-text-3
    elementType: text
    bounds: [120, 335, 40, 50]
    content:
      align: [center, middle]
      fontSize: 20
      color: "#FFFFFF"
      text: "03"

  - elementId: toc-content-3
    elementType: text
    bounds: [180, 340, 400, 40]
    content:
      style: "$bodyLarge"
      align: [left, middle]
      text: |
        <p>世界各地的茶道文化</p>

  # 目录项4
  - elementId: toc-num-4
    elementType: shape
    bounds: [120, 410, 40, 40]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"

  - elementId: toc-text-4
    elementType: text
    bounds: [120, 405, 40, 50]
    content:
      align: [center, middle]
      fontSize: 20
      color: "#FFFFFF"
      text: "04"

  - elementId: toc-content-4
    elementType: text
    bounds: [180, 410, 400, 40]
    content:
      style: "$bodyLarge"
      align: [left, middle]
      text: |
        <p>现代茶产业趋势</p>

  # 页码
  - elementId: page-number
    elementType: text
    bounds: [1180, 670, 80, 30]
    content:
      style: "$caption"
      align: [right, middle]
      text: |
        <p>02</p>
