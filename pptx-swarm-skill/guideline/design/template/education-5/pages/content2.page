pageType: content
background:
  type: solid
  color: "#F9F7F4"
elements:
  # Top 4px navy header line
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "#2B6777"

  # Chapter name header (left)
  - elementId: header-chapter
    elementType: text
    bounds: [60, 12, 700, 22]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:13px; color:#5E8B9E; font-family:SortsMillGoudy, MiSans, MiSans;">第二章 · 实证分析与主要发现</span></p>

  # Page number
  - elementId: header-pagenum
    elementType: text
    bounds: [1200, 12, 60, 22]
    content:
      align: [right, middle]
      wrap: false
      text: |
        <p><span style="font-size:13px; color:#8CA3AD; font-family:SortsMillGoudy, MiSans, MiSans;">05</span></p>

  # Main page title
  - elementId: page-title
    elementType: text
    bounds: [60, 50, 1160, 50]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:32px; color:#2B6777; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>数据可视化：核心指标趋势分析（2010-2024）</strong></span></p>

  # Gold line under title
  - elementId: title-gold-line
    elementType: shape
    bounds: [60, 106, 400, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#D4956A"

  # Chart area (60% of page width = ~768px)
  - elementId: chart-bg
    elementType: shape
    bounds: [60, 120, 768, 430]
    shapeName: rect
    fill:
      type: solid
      color: "#EDE9E3"
    border:
      style: none
      width: 0
      color: "#EDE9E3"

  - elementId: main-chart
    elementType: chart
    bounds: [70, 128, 748, 390]
    type: line
    title: "关键指标年度变化趋势"
    legend:
      show: true
      position: top
      fontSize: 13
    data:
      - {year: "2010", indicatorA: 42, indicatorB: 28, indicatorC: 35}
      - {year: "2012", indicatorA: 48, indicatorB: 32, indicatorC: 38}
      - {year: "2014", indicatorA: 55, indicatorB: 38, indicatorC: 44}
      - {year: "2016", indicatorA: 63, indicatorB: 45, indicatorC: 51}
      - {year: "2018", indicatorA: 71, indicatorB: 52, indicatorC: 58}
      - {year: "2020", indicatorA: 68, indicatorB: 55, indicatorC: 60}
      - {year: "2022", indicatorA: 78, indicatorB: 62, indicatorC: 67}
      - {year: "2024", indicatorA: 85, indicatorB: 70, indicatorC: 75}
    x: year
    y: [indicatorA, indicatorB, indicatorC]
    names: ["指标A", "指标B", "指标C"]
    colors: ["#2B6777", "#D4956A", "#C17050"]
    seriesStyle:
      "*":
        smooth: true
        width: 2
        marker:
          shape: circle
          size: 5
      indicatorA:
        width: 3
      indicatorB:
        line: dash
      indicatorC:
        line: dot
    xAxis:
      label:
        color: "#5E8B9E"
        fontSize: 13
      gridLine:
        color: "#D6CFC4"
        style: dot
    yAxis:
      label:
        color: "#5E8B9E"
        fontSize: 13
      gridLine:
        color: "#D6CFC4"
        style: dot
    options:
      fontFamily: "Liter, MiSans, MiSans"

  # Data source note
  - elementId: data-source
    elementType: text
    bounds: [70, 556, 748, 20]
    content:
      wrap: false
      text: |
        <p><span style="font-size:13px; font-style:italic; color:#5E8B9E; font-family:SortsMillGoudy, MiSans, MiSans;">数据来源：XXX统计数据库，2024年</span></p>

  # Right analysis column (35% width ≈ 390px, starts at x=868)
  - elementId: analysis-title
    elementType: text
    bounds: [868, 120, 372, 30]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:18px; color:#2B6777; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>分析要点</strong></span></p>

  - elementId: analysis-divider
    elementType: shape
    bounds: [868, 156, 200, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#D4956A"

  # Analysis bullet 1
  - elementId: analysis-num-1
    elementType: text
    bounds: [868, 172, 44, 36]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:20px; color:#D4956A; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>①</strong></span></p>

  - elementId: analysis-text-1
    elementType: text
    bounds: [918, 166, 322, 116]
    content:
      fontSize: 20
      color: "#2C3E50"
      fontFamily: "SortsMillGoudy, siyuanSongti, MiSans"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:20px; font-family:SortsMillGoudy, MiSans, MiSans; color:#2C3E50;"><strong>持续上升趋势</strong>：指标A自2010年以来呈显著上升，年均增长率达<span style="color:#D4956A; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>5.2%</strong></span></span></p>

  # Analysis bullet 2
  - elementId: analysis-num-2
    elementType: text
    bounds: [868, 302, 44, 36]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:20px; color:#D4956A; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>②</strong></span></p>

  - elementId: analysis-text-2
    elementType: text
    bounds: [918, 296, 322, 116]
    content:
      fontSize: 20
      color: "#2C3E50"
      fontFamily: "SortsMillGoudy, siyuanSongti, MiSans"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:20px; font-family:SortsMillGoudy, MiSans, MiSans; color:#2C3E50;"><strong>2020年异常波动</strong>：受外部冲击影响，指标短期回落，但恢复弹性强劲，印证理论预测</span></p>

  # Analysis bullet 3
  - elementId: analysis-num-3
    elementType: text
    bounds: [868, 432, 44, 36]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:20px; color:#D4956A; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>③</strong></span></p>

  - elementId: analysis-text-3
    elementType: text
    bounds: [918, 426, 322, 116]
    content:
      fontSize: 20
      color: "#2C3E50"
      fontFamily: "SortsMillGoudy, siyuanSongti, MiSans"
      lineHeight: 1.5
      wrap: true
      text: |
        <p><span style="font-size:20px; font-family:SortsMillGoudy, MiSans, MiSans; color:#2C3E50;"><strong>指标B与C协同</strong>：相关系数达<span style="color:#D4956A; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>0.87</strong></span>，支持核心假设H1的成立</span></p>

  # Footer reference area
  - elementId: footer-line
    elementType: shape
    bounds: [60, 620, 1160, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#D6CFC4"

  - elementId: footer-ref
    elementType: text
    bounds: [60, 628, 1100, 28]
    content:
      fontSize: 13
      color: "#5E8B9E"
      fontFamily: "Liter, MiSans, MiSans"
      lineHeight: 1.3
      wrap: false
      text: |
        <p><span style="font-size:13px; font-style:italic; color:#5E8B9E; font-family:SortsMillGoudy, MiSans, MiSans;">数据来源：XXX国家统计局/学术数据库，2010-2024年。统计方法：OLS回归，稳健标准误。</span></p>
