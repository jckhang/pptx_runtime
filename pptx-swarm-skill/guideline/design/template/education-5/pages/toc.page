pageType: table_of_contents
background:
  type: solid
  color: "#F9F7F4"
elements:
  # Top header bar (4px navy line)
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "#2B6777"

  # Left watermark "CONTENTS"
  - elementId: watermark-text
    elementType: text
    bounds: [20, 240, 340, 160]
    opacity: 0.10
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p style="text-align:center"><span style="font-size:56px; color:#2B6777; font-family:SortsMillGoudy, siyuanSongti, MiSans;"><strong>CONTENTS</strong></span></p>

  # Left vertical gold divider line
  - elementId: left-divider
    elementType: shape
    bounds: [360, 60, 0, 600]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#D4956A"

  # Page header label
