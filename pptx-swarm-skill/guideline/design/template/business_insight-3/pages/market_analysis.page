pageType: content
background:
  type: solid
  color: "$background"
elements:
  # ALL CAPS page title
  - elementId: page-title
    elementType: text
    bounds: [50, 18, 900, 42]
    content:
      align: [left, middle]
      wrap: true
      lineHeight: 1.2
      text: |
        <p><span style="font-size:24px; color:#2C2C2C; font-family:Liter, MiSans;"><strong>市场结构性分散创造明确整合机会，龙头战略卡位至关重要</strong></span></p>

  # English subtitle
  - elementId: page-subtitle
    elementType: text
    bounds: [50, 62, 900, 24]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:14px; color:#888888; font-family:Liter, MiSans;">STRUCTURAL FRAGMENTATION CREATES CLEAR CONSOLIDATION OPPORTUNITY</span></p>

  # 2px red line
  - elementId: title-red-line
    elementType: shape
    bounds: [50, 88, 800, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$primary"}

  # Left: CR5/CR10 trend combo chart (fills upper-left area)
  - elementId: trend-chart-title
    elementType: text
    bounds: [50, 96, 560, 24]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:14px; color:#2C2C2C; font-family:Liter, MiSans;"><strong>行业集中度趋势与市场份额演变（2020–2025E）</strong></span></p>

  - elementId: trend-chart
    elementType: chart
    bounds: [50, 124, 560, 320]
    type: combo
    options:
      fontFamily: "Liter, MiSans"
      barWidth: 0.5
    data:
      - {year: "2020", cr5: 45, cr10: 62, others: 38}
      - {year: "2021", cr5: 49, cr10: 65, others: 35}
      - {year: "2022", cr5: 53, cr10: 68, others: 32}
      - {year: "2023", cr5: 57, cr10: 71, others: 29}
      - {year: "2024", cr5: 60, cr10: 74, others: 26}
      - {year: "2025E", cr5: 62, cr10: 76, others: 24}
    x: year
    y: [cr5, cr10, others]
    names: ["CR5(%)", "CR10(%)", "其他(%)"]
    colors: ["$primary", "$chartcolor2", "$border"]
    seriesStyle:
      cr5: {type: bar}
      cr10:
        type: line
        smooth: true
        width: 3
        marker:
          shape: circle
          size: 6
          fill: {type: solid, color: "$chartcolor2"}
      others:
        type: line
        axis: secondary
        smooth: true
        width: 2
        line: dash
        marker: false
    legend: {position: top, fontSize: 11}
    dataLabels:
      show: true
      content: value
      fontSize: 10
    xAxis:
      label: {fontSize: 12, color: "$text"}
      gridLine: false
    yAxis:
      label: {fontSize: 11, color: "$medgray"}
      gridLine: {color: "#EEEEEE", style: dash}
      min: 30
      max: 80
    secondaryAxis:
      label: {fontSize: 10, color: "$medgray"}
      min: 20
      max: 45

  # 3 callout stats
  - elementId: pie-stat1-num
    elementType: text
    bounds: [50, 456, 180, 44]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:34px; color:#D91E18; font-family:Liter, MiSans;"><strong>CR2 41%</strong></span></p>

  - elementId: pie-stat1-label
    elementType: text
    bounds: [50, 502, 180, 22]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:12px; color:#888888; font-family:Liter, MiSans;">前二名合计 Top-2 Share</span></p>

  - elementId: pie-stat2-num
    elementType: text
    bounds: [240, 456, 180, 44]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:34px; color:#D91E18; font-family:Liter, MiSans;"><strong>+8pp</strong></span></p>

  - elementId: pie-stat2-label
    elementType: text
    bounds: [240, 502, 180, 22]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:12px; color:#888888; font-family:Liter, MiSans;">5年集中度提升 5Y Gain</span></p>

  - elementId: pie-stat3-num
    elementType: text
    bounds: [430, 456, 180, 44]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:34px; color:#2C2C2C; font-family:Liter, MiSans;"><strong>30%↓</strong></span></p>

  - elementId: pie-stat3-label
    elementType: text
    bounds: [430, 502, 180, 22]
    content:
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:12px; color:#888888; font-family:Liter, MiSans;">尾部份额持续萎缩</span></p>

  # Bottom analysis summary
  - elementId: left-summary-bg
    elementType: shape
    bounds: [50, 536, 560, 110]
    shapeName: rect
    fill:
      type: solid
      color: "#FFFFFF"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: left-summary-accent
    elementType: shape
    bounds: [50, 536, 4, 110]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: left-summary
    elementType: text
    bounds: [66, 544, 530, 94]
    content:
      fontSize: 13
      color: "$text"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      wrap: true
      text: |
        <p><span style="color:#D91E18;"><strong>核心判断：</strong></span>市场整合窗口期已至，CR5从45%升至62%，年均提升3.4pp。龙头A+B合计份额突破41%，规模效应形成正循环。尾部30%份额将在未来3年加速出清。</p>

  # Right: 4 competitive dimension blocks with red left-border headers
  # Block 1
  - elementId: comp-border1
    elementType: shape
    bounds: [640, 94, 3, 24]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: comp-label1
    elementType: text
    bounds: [648, 94, 592, 24]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:11px; color:#888888; font-family:Liter, MiSans;"><strong>VALUE PROPOSITION 价值主张</strong></span></p>

  - elementId: comp-content1
    elementType: text
    bounds: [648, 124, 582, 90]
    content:
      fontSize: 13
      color: "$text"
      lineHeight: 1.55
      wrap: true
      text: |
        <p><span style="font-size:13px; font-family:Liter, MiSans;">龙头企业以"品质+服务+规模"构建差异化价值体系；挑战者以价格竞争为主；尾部企业价值定位模糊，客户黏性低，面临出清压力。</span></p>

  # Block 2
  - elementId: comp-border2
    elementType: shape
    bounds: [640, 222, 3, 24]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: comp-label2
    elementType: text
    bounds: [648, 222, 592, 24]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:11px; color:#888888; font-family:Liter, MiSans;"><strong>CHANNEL STRATEGY 渠道策略</strong></span></p>

  - elementId: comp-content2
    elementType: text
    bounds: [648, 252, 582, 90]
    content:
      fontSize: 13
      color: "$text"
      lineHeight: 1.55
      wrap: true
      text: |
        <p><span style="font-size:13px; font-family:Liter, MiSans;">龙头已完成线上线下一体化布局，直销占比超60%；中小企业仍依赖传统经销商，渠道成本高、响应慢，数字化转型滞后。</span></p>

  # Block 3
  - elementId: comp-border3
    elementType: shape
    bounds: [640, 350, 3, 24]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: comp-label3
    elementType: text
    bounds: [648, 350, 592, 24]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:11px; color:#888888; font-family:Liter, MiSans;"><strong>TECHNOLOGY MOAT 技术壁垒</strong></span></p>

  - elementId: comp-content3
    elementType: text
    bounds: [648, 380, 582, 90]
    content:
      fontSize: 13
      color: "$text"
      lineHeight: 1.55
      wrap: true
      text: |
        <p><span style="font-size:13px; font-family:Liter, MiSans;">龙头研发投入占营收18%+，AI与数字化能力已形成竞争壁垒；中小企业研发费用率仅6-10%，难以在技术维度实现突破。</span></p>

  # Block 4
  - elementId: comp-border4
    elementType: shape
    bounds: [640, 478, 3, 24]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: comp-label4
    elementType: text
    bounds: [648, 478, 592, 24]
    content:
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="font-size:11px; color:#888888; font-family:Liter, MiSans;"><strong>STRATEGIC OUTLOOK 战略展望</strong></span></p>

  - elementId: comp-content4
    elementType: text
    bounds: [648, 508, 582, 130]
    content:
      fontSize: 13
      color: "$text"
      lineHeight: 1.55
      wrap: true
      text: |
        <p><span style="font-size:13px; font-family:Liter, MiSans;">建议聚焦龙头A与龙头B的核心赛道，把握市场整合窗口期；关注技术壁垒高、现金流稳健的标的；规避尾部高风险企业。</span></p>

  # Footer line
  - elementId: footer-line
    elementType: shape
    bounds: [50, 656, 1180, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  # Source
  - elementId: source-text
    elementType: text
    bounds: [50, 662, 700, 22]
    content:
      style: "$caption"
      wrap: false
      text: |
        <p>数据来源：行业协会、公司年报、Bain市场研究数据库</p>

  # Page number
  - elementId: page-number
    elementType: text
    bounds: [1130, 662, 100, 22]
    content:
      align: [right, middle]
      fontSize: 12
      color: "$medgray"
      wrap: false
      text: |
        <p>07</p>
