pageType: content
background:
  type: solid
  color: "$background"
elements:
  # Top structural bar
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # Gold vertical accent bar left of title
  - elementId: title-accent-bar
    elementType: shape
    bounds: [50, 10, 4, 54]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # Page action title
  - elementId: page-title
    elementType: text
    bounds: [62, 12, 1150, 50]
    content:
      align: [left, middle]
      wrap: true
      text: |
        <p><span style="font-size:22px; color:#0F2647; font-family:Palatino Linotype, SimSun, MiSans;"><strong>从宏观到微观：五步研究框架助力系统性把握行业投资机会</strong></span></p>

  # Horizontal divider
  - elementId: title-divider
