pageType: final
background:
  type: solid
  color: "$background"
elements:
  # 装饰线
  - elementId: deco-line
    elementType: shape
    bounds: [540, 240, 200, 2]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 感谢语
  - elementId: thank-you
    elementType: text
    bounds: [240, 270, 800, 60]
    content:
      text: |
        <p><strong>Thank You for Your Guidance</strong></p>
      fontSize: 36
      color: "$accent"
      fontFamily: "Oranienbaum, MiSans"
      align: [center, middle]

  # 展望语
  - elementId: outlook
    elementType: text
    bounds: [290, 340, 700, 50]
    content:
      text: |
        <p>Together, we build sustainable growth and lasting impact.</p>
      fontSize: 22
      color: "$lightText"
      fontFamily: "Liter, MiSans"
      align: [center, middle]

  # 分隔线
  - elementId: divider
    elementType: shape
    bounds: [540, 420, 200, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  # 联系信息
  - elementId: contact
    elementType: text
    bounds: [340, 450, 600, 80]
    content:
      text: |
        <p><strong>XXX</strong> · Chief Executive Officer</p>
        <p style="color:#9CA3AF">xxx@company.com · +X (XXX) XXX-XXXX</p>
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      align: [center, middle]

  # 公司标识
  - elementId: company
    elementType: text
    bounds: [440, 560, 400, 30]
    content:
      text: "Company Name · Confidential"
      fontSize: 14
      color: "$lightText"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
