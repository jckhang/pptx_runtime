pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 导航栏背景
  - elementId: nav-bar
    elementType: shape
    bounds: [0, 0, 1280, 56]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border:
      style: solid
      width: 1
      color: "#EAE8E3"

  # 选中项指示条
  - elementId: nav-indicator
    elementType: shape
    bounds: [100, 52, 190, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: nav-item1
    elementType: text
    bounds: [100, 10, 190, 36]
    content:
      text: |
        <p><strong>Performance Overview</strong></p>
      fontSize: 15
      color: "$primary"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false

  - elementId: nav-item2
    elementType: text
    bounds: [310, 10, 170, 36]
    content:
      text: "Strategic Initiatives"
      fontSize: 15
      color: "#C8C8C4"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false

  - elementId: nav-item3
    elementType: text
    bounds: [500, 10, 195, 36]
    content:
      text: "Organization & Talent"
      fontSize: 15
      color: "#C8C8C4"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false

  - elementId: nav-item4
    elementType: text
    bounds: [715, 10, 175, 36]
    content:
      text: "Reflection & Forward"
      fontSize: 15
      color: "#C8C8C4"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false

  # 页面标题
  - elementId: page-title
    elementType: text
    bounds: [100, 90, 900, 50]
    content:
      text: |
        <p><strong>Revenue Trajectory: Consistent Growth Pattern</strong></p>
      fontSize: 32
      color: "$accent"
      fontFamily: "Liter, MiSans"
      align: [left, middle]

  # 分割线
  - elementId: divider
    elementType: shape
    bounds: [100, 155, 1080, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  # 折线图
  - elementId: revenue-chart
    elementType: chart
    bounds: [100, 190, 1080, 360]
    type: line
    data:
      - {quarter: "Q1 2024", revenue: 280, target: 270}
      - {quarter: "Q2 2024", revenue: 295, target: 285}
      - {quarter: "Q3 2024", revenue: 310, target: 300}
      - {quarter: "Q4 2024", revenue: 322, target: 315}
    x: quarter
    y: [revenue, target]
    names: ["Actual", "Target"]
    colors: ["$primary", "$lightText"]
    options:
      fontFamily: "Liter, MiSans"
    seriesStyle:
      "*":
        smooth: true
        width: 2
        marker:
          size: 6
          fill: {type: solid, color: "$white"}
          border: {style: solid, width: 2, color: "$primary"}
      revenue:
        width: 3
      target:
        line: dash
        marker: false
    xAxis:
      axisLine: false
      gridLine: false
      label:
        color: "$lightText"
        fontSize: 14
    yAxis:
      axisLine: false
      gridLine: false
      min: 250
      max: 350
      label:
        color: "$lightText"
        fontSize: 14
    fill:
      type: solid
      color: "$white"

  # 底部洞察
  - elementId: insight
    elementType: text
    bounds: [100, 570, 1080, 50]
    content:
      text: |
        <p>Key Insight: Q4 performance exceeded targets by <strong>2.2%</strong>, driven by strategic market expansion and operational excellence.</p>
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, MiSans"
      align: [center, middle]

  # 页码
  - elementId: page-number
    elementType: text
    bounds: [1180, 660, 80, 30]
    content:
      text: "05"
      style: "$caption"
      align: [right, bottom]
