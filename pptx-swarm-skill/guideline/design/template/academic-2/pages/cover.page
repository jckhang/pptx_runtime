pageType: cover
background:
  type: solid
  color: "$background"
elements:
  # 顶部深红渐变色带（约页面上方40%）
  - elementId: cover-top-band
    elementType: shape
    bounds: [0, 0, 1280, 288]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 180
      stops:
        - {position: 0, color: "#5A0A0A"}
        - {position: 0.5, color: "#8B1A1A"}
        - {position: 1, color: "#A52020"}

  # 顶部校徽占位圆
  - elementId: cover-logo
    elementType: shape
    bounds: [60, 30, 54, 54]
    shapeName: ellipse
    fill:
      type: solid
      color: "#FFFFFF25"
    border:
      style: solid
      width: 2
      color: "#B8860B"

  # 校名
  - elementId: cover-university
    elementType: text
    bounds: [128, 34, 320, 28]
    content:
      fontSize: 22
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>XX大学</strong></p>

  - elementId: cover-university-en
    elementType: text
    bounds: [128, 62, 320, 22]
    content:
      fontSize: 12
      color: "#FFFFFFAA"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: XX University

  # PPT类型标签（金色）
  - elementId: cover-type-badge
    elementType: shape
    bounds: [60, 120, 180, 36]
    shapeName: rect
    fill:
      type: solid
      color: "#B8860B"

  - elementId: cover-type-text
    elementType: text
    bounds: [60, 120, 180, 36]
    content:
      fontSize: 14
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 博士论文答辩

  # 主标题区（色带内下方）
  - elementId: cover-main-title
    elementType: text
    bounds: [60, 168, 1000, 60]
    content:
      style: "$title"
      fontSize: 44
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>论文答辩/开题报告PPT模板</strong></p>

  - elementId: cover-subtitle-en
    elementType: text
    bounds: [60, 236, 900, 30]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      letterSpacing: 2
      wrap: false
      text: |
        <p>DISSERTATION DEFENSE / THESIS PROPOSAL</p>

  # 金色分隔线
  - elementId: cover-gold-line
    elementType: shape
    bounds: [60, 300, 600, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "#B8860B"

  # 信息区域（色带下方白色区域）
  - elementId: cover-author-label
    elementType: text
    bounds: [60, 330, 120, 22]
    content:
      fontSize: 13
      color: "#999999"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: 答辩人

  - elementId: cover-author
    elementType: text
    bounds: [60, 352, 250, 28]
    content:
      fontSize: 20
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>XXX</strong></p>

  - elementId: cover-advisor-label
    elementType: text
    bounds: [320, 330, 120, 22]
    content:
      fontSize: 13
      color: "#999999"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: 指导教师

  - elementId: cover-advisor
    elementType: text
    bounds: [320, 352, 300, 28]
    content:
      fontSize: 20
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>XXX 教授</strong></p>

  - elementId: cover-dept
    elementType: text
    bounds: [60, 410, 600, 26]
    content:
      fontSize: 16
      color: "#555555"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p>XX学院 · XX专业</p>

  - elementId: cover-date
    elementType: text
    bounds: [60, 445, 200, 24]
    content:
      fontSize: 14
      color: "#888888"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: 2025年X月

  # 右侧几何装饰
  - elementId: cover-deco-rect-1
    elementType: shape
    bounds: [1050, 340, 200, 200]
    shapeName: rect
    fill:
      type: solid
      color: "#8B1A1A08"
    border:
      style: solid
      width: 1
      color: "#8B1A1A20"

  - elementId: cover-deco-rect-2
    elementType: shape
    bounds: [1080, 370, 160, 160]
    shapeName: rect
    fill:
      type: solid
      color: "#B8860B08"
    border:
      style: solid
      width: 1
      color: "#B8860B25"

  # 底部金色装饰线
  - elementId: cover-bottom-gold-line
    elementType: shape
    bounds: [0, 700, 1280, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 3
      color: "#B8860B"

  # 底部校训
  - elementId: cover-motto
    elementType: text
    bounds: [900, 670, 330, 24]
    content:
      fontSize: 14
      color: "#B8860B"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: 自强不息，厚德载物
