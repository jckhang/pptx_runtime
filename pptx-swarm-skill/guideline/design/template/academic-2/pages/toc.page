pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 左侧暗红色块
  - elementId: toc-left-bg
    elementType: shape
    bounds: [0, 0, 380, 720]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 180
      stops:
        - {position: 0, color: "#5A0A0A"}
        - {position: 1, color: "#8B1A1A"}

  # 左侧"目录"大字
  - elementId: toc-title-cn
    elementType: text
    bounds: [40, 260, 300, 70]
    content:
      fontSize: 52
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>目录</strong></p>

  - elementId: toc-title-en
    elementType: text
    bounds: [40, 335, 300, 28]
    content:
      fontSize: 16
      color: "#FFFFFFAA"
      fontFamily: "QuattrocentoSans, MiSans"
      letterSpacing: 4
      wrap: false
      text: CONTENTS

  # 左侧金色分隔线（目录标题上方）
  - elementId: toc-gold-deco
    elementType: shape
    bounds: [40, 248, 80, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 3
      color: "#B8860B"

  # 右侧目录区 - 条目1
  - elementId: toc-num-1
    elementType: text
    bounds: [430, 120, 64, 45]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>01</strong></p>

  - elementId: toc-item-1
    elementType: text
    bounds: [500, 120, 400, 28]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>研究背景与问题提出</strong></p>

  - elementId: toc-item-1-sub
    elementType: text
    bounds: [500, 152, 400, 20]
    content:
      fontSize: 13
      color: "#999999"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: Background and Problem Statement

  - elementId: toc-gold-line-1
    elementType: shape
    bounds: [430, 192, 790, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#B8860B50"

