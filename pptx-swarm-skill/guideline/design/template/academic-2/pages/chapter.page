pageType: chapter
background:
  type: solid
  color: "$background"
elements:
  # 右侧 2/3 暗红背景
  - elementId: chapter-right-bg
    elementType: shape
    bounds: [400, 0, 880, 720]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 90
      stops:
        - {position: 0, color: "#8B1A1A"}
        - {position: 1, color: "#5A0A0A"}

  # 左侧白色区域 - 超大金色章节数字
  - elementId: chapter-num
    elementType: text
    bounds: [40, 220, 340, 200]
    content:
      fontSize: 140
      color: "$gold"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>01</strong></p>

  # 左侧底部金色横线
  - elementId: chapter-gold-line
    elementType: shape
    bounds: [40, 440, 320, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 3
      color: "#B8860B"

  # 右侧章节标题（白色）
  - elementId: chapter-title
    elementType: text
    bounds: [460, 260, 720, 60]
    content:
      fontSize: 38
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>研究背景与问题提出</strong></p>

  - elementId: chapter-title-en
    elementType: text
    bounds: [460, 330, 700, 28]
    content:
      fontSize: 18
      color: "#FFFFFFAA"
      fontFamily: "QuattrocentoSans, MiSans"
      letterSpacing: 2
      wrap: false
      text: Background and Problem Statement

  # 右侧子章节列表
  - elementId: chapter-sub-1
    elementType: text
    bounds: [460, 400, 700, 26]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p>1.1　研究背景与意义</p>

  - elementId: chapter-sub-2
    elementType: text
    bounds: [460, 434, 700, 26]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p>1.2　国内外研究现状</p>

  - elementId: chapter-sub-3
    elementType: text
    bounds: [460, 468, 700, 26]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p>1.3　研究问题与目标</p>

  # 右侧装饰线（章节标题上方）
  - elementId: chapter-deco-line
    elementType: shape
    bounds: [460, 248, 200, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "#B8860B"

  # 右下角页码
  - elementId: chapter-page-num
    elementType: text
    bounds: [1200, 680, 50, 24]
    content:
      fontSize: 14
      color: "#FFFFFFAA"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: "3"
