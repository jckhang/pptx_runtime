pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 顶部导航条（各章节标题均匀分布）
  - elementId: nav-bg
    elementType: shape
    bounds: [0, 0, 1280, 44]
    shapeName: rect
    fill:
      type: solid
      color: "$navBg"

  - elementId: nav-active
    elementType: shape
    bounds: [768, 0, 256, 44]
    shapeName: rect
    fill:
      type: solid
      color: "$white"

  - elementId: nav-ch1
    elementType: text
    bounds: [0, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 01 研究背景

  - elementId: nav-div1
    elementType: shape
    bounds: [256, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch2
    elementType: text
    bounds: [256, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 02 文献综述

  - elementId: nav-div2
    elementType: shape
    bounds: [512, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch3
    elementType: text
    bounds: [512, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 03 研究方法

  - elementId: nav-div3
    elementType: shape
    bounds: [768, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch4
    elementType: text
    bounds: [768, 0, 256, 44]
    content:
      fontSize: 13
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 04 实验结果

  - elementId: nav-div4
    elementType: shape
    bounds: [1024, 6, 0, 32]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  - elementId: nav-ch5
    elementType: text
    bounds: [1024, 0, 256, 44]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 05 结论展望

  # 标题
  - elementId: title-deco-line
    elementType: shape
    bounds: [50, 62, 0, 36]
    shapeName: straightConnector1
    border:
      style: solid
      width: 4
      color: "$primary"

  - elementId: page-title
    elementType: text
    bounds: [68, 60, 900, 40]
    content:
      style: "$pageTitle"
      wrap: false
      text: |
        <p><strong>关键性能指标一览</strong></p>

  - elementId: title-gold-line
    elementType: shape
    bounds: [50, 108, 1180, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#B8860B60"

  # 数据卡片 1
  - elementId: data-card-1-bg
    elementType: shape
    bounds: [50, 124, 270, 140]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: data-card-1-num
    elementType: text
    bounds: [50, 140, 270, 70]
    content:
      fontSize: 52
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>94.3%</strong></p>

  - elementId: data-card-1-label
    elementType: text
    bounds: [50, 216, 270, 32]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: Accuracy（准确率）

  # 数据卡片 2
  - elementId: data-card-2-bg
    elementType: shape
    bounds: [340, 124, 270, 140]
    shapeName: rect
    fill:
      type: solid
      color: "$gold"

  - elementId: data-card-2-num
    elementType: text
    bounds: [340, 140, 270, 70]
    content:
      fontSize: 52
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>91.7%</strong></p>

  - elementId: data-card-2-label
    elementType: text
    bounds: [340, 216, 270, 32]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: F1-Score（调和均值）

  # 数据卡片 3
  - elementId: data-card-3-bg
    elementType: shape
    bounds: [630, 124, 270, 140]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: data-card-3-num
    elementType: text
    bounds: [630, 140, 270, 70]
    content:
      fontSize: 52
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>+5.2%</strong></p>

  - elementId: data-card-3-label
    elementType: text
    bounds: [630, 216, 270, 32]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 相对基线提升幅度

  # 数据卡片 4
  - elementId: data-card-4-bg
    elementType: shape
    bounds: [920, 124, 310, 140]
    shapeName: rect
    fill:
      type: solid
      color: "#5A0A0A"

  - elementId: data-card-4-num
    elementType: text
    bounds: [920, 140, 310, 70]
    content:
      fontSize: 52
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>3×</strong></p>

  - elementId: data-card-4-label
    elementType: text
    bounds: [920, 216, 310, 32]
    content:
      fontSize: 16
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: 推理速度提升倍数

  # 性能对比柱状图
  - elementId: perf-chart
    elementType: chart
    bounds: [50, 282, 780, 330]
    type: bar
    data:
      - {dataset: "Dataset A", ours: 93.2, baseline1: 88.5, baseline2: 86.1}
      - {dataset: "Dataset B", ours: 94.3, baseline1: 86.5, baseline2: 84.8}
      - {dataset: "Dataset C", ours: 91.8, baseline1: 87.2, baseline2: 85.5}
      - {dataset: "Dataset D", ours: 95.1, baseline1: 90.3, baseline2: 88.7}
      - {dataset: "Dataset E", ours: 92.5, baseline1: 88.9, baseline2: 87.1}
    x: dataset
    y: [ours, baseline1, baseline2]
    names: ["Ours", "Baseline-1", "Baseline-2"]
    colors: ["$primary", "$gold", "$secondary"]
    options:
      barWidth: 0.7
      fontFamily: "QuattrocentoSans, MiSans"
    xAxis:
      label:
        fontSize: 14
        color: "$text"
    yAxis:
      title: "Accuracy (%)"
      min: 80
      max: 100
      gridLine:
        color: "#8B1A1A20"
        style: dash
      label:
        fontSize: 13
        color: "#666666"
    legend:
      position: top
      fontSize: 14
    fill:
      type: solid
      color: "$lightRed"
    border:
      style: solid
      width: 1
      color: "#8B1A1A40"

  # 右侧分析文字
  - elementId: analysis-title
    elementType: text
    bounds: [860, 290, 370, 26]
    content:
      fontSize: 18
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>结果分析</strong></p>

  - elementId: analysis-content
    elementType: text
    bounds: [860, 320, 370, 290]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: true
      lineHeight: 1.8
      text: |
        <p>• 在全部5个基准数据集上均超越当前最优基线方法</p>
        <p>• 准确率最大提升幅度达7.8%（数据集B）</p>
        <p>• 计算开销仅增加约12%，效率收益显著</p>
        <p>• 在小样本场景下优势更为突出（提升>10%）</p>
        <p>• 消融实验证实各模块均有显著贡献</p>
        <p>• 跨数据集泛化性能稳定，标准差<1.5%</p>

  # 底部金线
  - elementId: bottom-gold-line
    elementType: shape
    bounds: [0, 706, 1280, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "#B8860B"
