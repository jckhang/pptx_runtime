pageType: cover
background:
  type: gradient
  gradientType: linear
  angle: 135
  stops:
    - {position: 0, color: "#2D1B55"}
    - {position: 0.5, color: "#432879"}
    - {position: 1, color: "#5A4892"}
elements:
  # 顶部细白色横线
  - elementId: cover-top-line
    elementType: shape
    bounds: [0, 0, 1280, 2]
    shapeName: rect
    fill:
      type: solid
      color: "#FFFFFF30"

  # 顶部左侧白色细条
  - elementId: cover-top-bar
    elementType: shape
    bounds: [0, 0, 80, 100]
    shapeName: rect
    fill:
      type: solid
      color: "#FFFFFF08"

  # 校名区域
  - elementId: cover-logo
    elementType: shape
    bounds: [50, 24, 44, 44]
    shapeName: ellipse
    fill:
      type: solid
      color: "#FFFFFF20"
    border:
      style: solid
      width: 1
      color: "#8A7BB5"

  - elementId: cover-university
    elementType: text
    bounds: [106, 28, 300, 26]
    content:
      fontSize: 18
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p><strong>XX大学</strong></p>

  - elementId: cover-university-en
    elementType: text
    bounds: [106, 54, 300, 18]
    content:
      fontSize: 11
      color: "#FFFFFF88"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: XX University

  # 类型标签
  - elementId: cover-type-tag
    elementType: shape
    bounds: [50, 120, 220, 32]
    shapeName: roundRect
    adjustments: [16000]
    fill:
      type: solid
      color: "#FFFFFF20"
    border:
      style: solid
      width: 1
      color: "#8A7BB5"

  - elementId: cover-type-text
    elementType: text
    bounds: [50, 120, 220, 32]
    content:
      fontSize: 13
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      letterSpacing: 2
      wrap: false
      text: DOCTORAL DISSERTATION

  # 主标题（左下区域）
  - elementId: cover-main-title
    elementType: text
    bounds: [50, 180, 1000, 80]
    content:
      style: "$title"
      fontSize: 46
      align: [left, top]
      wrap: true
      text: |
        <p><strong>面向复杂场景的深度学习模型研究</strong></p>

  - elementId: cover-subtitle-en
    elementType: text
    bounds: [50, 272, 900, 28]
    content:
      fontSize: 16
      color: "#FFFFFFAA"
      fontFamily: "QuattrocentoSans, MiSans"
      letterSpacing: 1
      wrap: false
      text: Deep Learning Model Research for Complex Scenarios

  # 浅色渐变分隔线
  - elementId: cover-title-sep
    elementType: shape
    bounds: [50, 316, 400, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "#8A7BB5"

  # 信息区
  - elementId: cover-author
    elementType: text
    bounds: [50, 336, 500, 28]
    content:
      fontSize: 18
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: |
        <p>答辩人：XXX　|　指导教师：XXX 教授</p>

  - elementId: cover-dept
    elementType: text
    bounds: [50, 374, 600, 24]
    content:
      fontSize: 14
      color: "#FFFFFF88"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: XX学院 · 计算机科学与技术

  - elementId: cover-date
    elementType: text
    bounds: [50, 408, 200, 22]
    content:
      fontSize: 14
      color: "#FFFFFF66"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: 2025年X月

  # 右侧几何装饰叠加
  - elementId: cover-deco-big-rect
    elementType: shape
    bounds: [860, 160, 380, 380]
    shapeName: rect
    fill:
      type: solid
      color: "#FFFFFF06"
    border:
      style: solid
      width: 1
      color: "#FFFFFF15"

  - elementId: cover-deco-mid-rect
    elementType: shape
    bounds: [900, 200, 300, 300]
    shapeName: rect
    fill:
      type: solid
      color: "#8A7BB50A"
    border:
      style: solid
      width: 1
      color: "#8A7BB525"

  - elementId: cover-deco-small-rect
    elementType: shape
    bounds: [950, 250, 200, 200]
    shapeName: rect
    fill:
      type: solid
      color: "#FFFFFF08"
    border:
      style: solid
      width: 1
      color: "#FFFFFF20"

  # 右下角装饰点
  - elementId: cover-dot-1
    elementType: shape
    bounds: [1180, 640, 12, 12]
    shapeName: ellipse
    fill:
      type: solid
      color: "#8A7BB5"

  - elementId: cover-dot-2
    elementType: shape
    bounds: [1206, 640, 8, 8]
    shapeName: ellipse
    fill:
      type: solid
      color: "#8A7BB580"

  - elementId: cover-dot-3
    elementType: shape
    bounds: [1228, 640, 6, 6]
    shapeName: ellipse
    fill:
      type: solid
      color: "#8A7BB540"
