pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 左侧细竖线
  - elementId: toc-left-line
    elementType: shape
    bounds: [0, 0, 6, 720]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 页面标题
  - elementId: toc-header
    elementType: text
    bounds: [60, 50, 300, 50]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>目录</strong></p>

  - elementId: toc-header-en
    elementType: text
    bounds: [60, 104, 300, 24]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "QuattrocentoSans, MiSans"
      letterSpacing: 4
      wrap: false
      text: TABLE OF CONTENTS

  - elementId: toc-header-separator
    elementType: shape
    bounds: [60, 138, 1160, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$borderGray"

  # 目录项 1
  - elementId: toc-num-1
    elementType: text
    bounds: [60, 158, 60, 50]
    content:
      fontSize: 28
      color: "$secondary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p>01</p>

  - elementId: toc-item-1
    elementType: text
    bounds: [130, 163, 700, 28]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>研究背景与问题提出</strong></p>

  - elementId: toc-item-1-en
    elementType: text
    bounds: [130, 193, 700, 20]
    content:
      fontSize: 13
      color: "#AAAAAA"
      fontFamily: "QuattrocentoSans, MiSans"
      wrap: false
      text: Background and Problem Statement

  - elementId: toc-sep-1
    elementType: shape
