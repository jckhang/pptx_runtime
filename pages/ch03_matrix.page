pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 页面标题
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 700, 40]
    content:
      style: "$pageTitle"
      wrap: false
      text: |
        <p><strong>工作模式矩阵</strong></p>

  # 标题装饰线
  - elementId: title-line
    elementType: shape
    bounds: [60, 88, 1160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$divider"

  # 内容模式区域标题
  - elementId: content-mode-label
    elementType: text
    bounds: [60, 110, 300, 26]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>CONTENT MODES</p>

  # 内容模式卡片 1 - Summary
  - elementId: cm-1-bg
    elementType: shape
    bounds: [60, 145, 370, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: cm-1-bar
    elementType: shape
    bounds: [60, 145, 4, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: cm-1-icon
    elementType: icon
    bounds: [80, 158, 22, 22]
    iconName: "fas:file-lines"
    fill:
      type: solid
      color: "$primary"

  - elementId: cm-1-title
    elementType: text
    bounds: [110, 155, 200, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>Summary 摘要模式</strong></p>

  - elementId: cm-1-desc
    elementType: text
    bounds: [80, 190, 330, 55]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      text: |
        <p>基于上传的长文档（论文、报告等）生成</p>
        <p>内容高度完整时进入此模式</p>

  # 内容模式卡片 2 - Outline
  - elementId: cm-2-bg
    elementType: shape
    bounds: [455, 145, 370, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: cm-2-bar
    elementType: shape
    bounds: [455, 145, 4, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: cm-2-icon
    elementType: icon
    bounds: [475, 158, 22, 22]
    iconName: "fas:list-check"
    fill:
      type: solid
      color: "$accent"

  - elementId: cm-2-title
    elementType: text
    bounds: [505, 155, 200, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>Outline 大纲模式</strong></p>

  - elementId: cm-2-desc
    elementType: text
    bounds: [475, 190, 330, 55]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      text: |
        <p>基于已提供的结构化大纲生成</p>
        <p>每页内容已规划好，直接编排</p>

  # 内容模式卡片 3 - Search
  - elementId: cm-3-bg
    elementType: shape
    bounds: [850, 145, 370, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: cm-3-bar
    elementType: shape
    bounds: [850, 145, 4, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: cm-3-icon
    elementType: icon
    bounds: [870, 158, 22, 22]
    iconName: "fas:magnifying-glass"
    fill:
      type: solid
      color: "$secondary"

  - elementId: cm-3-title
    elementType: text
    bounds: [900, 155, 200, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>Search 搜索模式</strong></p>

  - elementId: cm-3-desc
    elementType: text
    bounds: [870, 190, 330, 55]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      text: |
        <p>仅提供主题，需要搜索补充内容</p>
        <p>适合探索性、研究性主题</p>

  # 视觉模式区域标题
  - elementId: visual-mode-label
    elementType: text
    bounds: [60, 285, 300, 26]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>VISUAL MODES</p>

  # 视觉模式卡片 1 - Creative
  - elementId: vm-1-bg
    elementType: shape
    bounds: [60, 320, 370, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: vm-1-bar
    elementType: shape
    bounds: [60, 320, 4, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: vm-1-icon
    elementType: icon
    bounds: [80, 333, 22, 22]
    iconName: "fas:palette"
    fill:
      type: solid
      color: "$primary"

  - elementId: vm-1-title
    elementType: text
    bounds: [110, 330, 250, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>Creative 创意模式</strong></p>

  - elementId: vm-1-desc
    elementType: text
    bounds: [80, 365, 330, 55]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      text: |
        <p>无视觉参考，自主设计</p>
        <p>基于场景预设和风格锚点创作</p>

  # 视觉模式卡片 2 - Reference
  - elementId: vm-2-bg
    elementType: shape
    bounds: [455, 320, 370, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: vm-2-bar
    elementType: shape
    bounds: [455, 320, 4, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: vm-2-icon
    elementType: icon
    bounds: [475, 333, 22, 22]
    iconName: "fas:clone"
    fill:
      type: solid
      color: "$accent"

  - elementId: vm-2-title
    elementType: text
    bounds: [505, 330, 250, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>Reference 复刻模式</strong></p>

  - elementId: vm-2-desc
    elementType: text
    bounds: [475, 365, 330, 55]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      text: |
        <p>基于上传图片/网站复刻风格</p>
        <p>精确还原视觉特征和布局</p>

  # 视觉模式卡片 3 - Template
  - elementId: vm-3-bg
    elementType: shape
    bounds: [850, 320, 370, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: vm-3-bar
    elementType: shape
    bounds: [850, 320, 4, 115]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: vm-3-icon
    elementType: icon
    bounds: [870, 333, 22, 22]
    iconName: "fas:copy"
    fill:
      type: solid
      color: "$secondary"

  - elementId: vm-3-title
    elementType: text
    bounds: [900, 330, 250, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>Template 模板模式</strong></p>

  - elementId: vm-3-desc
    elementType: text
    bounds: [870, 365, 330, 55]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.6
      text: |
        <p>基于上传 PPT 模板创建</p>
        <p>继承模板的主题和布局规范</p>

  # 组合示例标题
  - elementId: combo-label
    elementType: text
    bounds: [60, 465, 400, 26]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>COMBINATION EXAMPLES</p>

  # 组合示例表格
  - elementId: combo-table
    elementType: table
    bounds: [60, 500, 1160, 130]
    columnWidths: [0.35, 0.35, 0.30]
    rowHeights: [0.33, 0.33, 0.34]
    style: "$default"
    rows:
      - - content:
            text: |
              <p><strong>用户场景</strong></p>
        - content:
            text: |
              <p><strong>内容模式</strong></p>
        - content:
            text: |
              <p><strong>视觉模式</strong></p>
      - - content:
            text: |
              <p>上传论文转 PPT</p>
        - content:
            text: |
              <p>Summary</p>
        - content:
            text: |
              <p>Creative</p>
      - - content:
            text: |
              <p>复刻网站设计风格</p>
        - content:
            text: |
              <p>Outline</p>
        - content:
            text: |
              <p>Reference</p>

  # 页码
  - elementId: page-num
    elementType: text
    bounds: [1170, 680, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>12</p>
