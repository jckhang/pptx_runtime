pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 页面标题
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 700, 40]
    content:
      style: "$pageTitle"
      wrap: false
      text: |
        <p><strong>修复策略</strong></p>

  # 标题装饰线
  - elementId: title-line
    elementType: shape
    bounds: [60, 88, 1160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$divider"

  # 修复优先级
  - elementId: prio-label
    elementType: text
    bounds: [60, 110, 400, 26]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>FIX PRIORITY</p>

  # 优先级步骤
  - elementId: prio-step-1
    elementType: shape
    bounds: [60, 148, 370, 60]
    shapeName: rect
    fill:
      type: solid
      color: "#FF6B6B"

  - elementId: prio-text-1
    elementType: text
    bounds: [60, 148, 370, 60]
    content:
      fontSize: 18
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>1. 修复所有 Error</strong></p>

  - elementId: prio-arrow-1
    elementType: shape
    bounds: [440, 172, 30, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border:
      style: solid
      width: 2
      color: "$text"

  - elementId: prio-step-2
    elementType: shape
    bounds: [480, 148, 370, 60]
    shapeName: rect
    fill:
      type: solid
      color: "#F5A623"

  - elementId: prio-text-2
    elementType: text
    bounds: [480, 148, 370, 60]
    content:
      fontSize: 18
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>2. 修复所有 Warning</strong></p>

  - elementId: prio-arrow-2
    elementType: shape
    bounds: [860, 172, 30, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border:
      style: solid
      width: 2
      color: "$text"

  - elementId: prio-step-3
    elementType: shape
    bounds: [900, 148, 320, 60]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: prio-text-3
    elementType: text
    bounds: [900, 148, 320, 60]
    content:
      fontSize: 18
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>3. 重新验证</strong></p>

  # 文本溢出修复策略
  - elementId: overflow-label
    elementType: text
    bounds: [60, 240, 400, 26]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>TEXT OVERFLOW FIX</p>

  # 高度溢出卡片
  - elementId: hfix-bg
    elementType: shape
    bounds: [60, 278, 565, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: hfix-bar
    elementType: shape
    bounds: [60, 278, 4, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: hfix-icon
    elementType: icon
    bounds: [82, 294, 22, 22]
    iconName: "fas:arrows-up-down"
    fill:
      type: solid
      color: "$primary"

  - elementId: hfix-title
    elementType: text
    bounds: [112, 292, 300, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>高度溢出修复</strong></p>

  - elementId: hfix-steps
    elementType: text
    bounds: [82, 330, 525, 130]
    content:
      fontSize: 15
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.8
      text: |
        <p><strong style="color:#3B6BFF;">1.</strong> 精简文字 — 压缩表达、合并要点</p>
        <p><strong style="color:#3B6BFF;">2.</strong> 减小字号 — 降低字体大小、行距</p>
        <p><strong style="color:#3B6BFF;">3.</strong> 扩大文本框 — 增加 bounds 高度</p>

  # 宽度溢出卡片
  - elementId: wfix-bg
    elementType: shape
    bounds: [655, 278, 565, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: wfix-bar
    elementType: shape
    bounds: [655, 278, 4, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: wfix-icon
    elementType: icon
    bounds: [677, 294, 22, 22]
    iconName: "fas:arrows-left-right"
    fill:
      type: solid
      color: "$accent"

  - elementId: wfix-title
    elementType: text
    bounds: [707, 292, 300, 28]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>宽度溢出修复</strong></p>

  - elementId: wfix-steps
    elementType: text
    bounds: [677, 330, 525, 130]
    content:
      fontSize: 15
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.8
      text: |
        <p><strong style="color:#00D4AA;">1.</strong> 精简文字 — 缩短文本内容</p>
        <p><strong style="color:#00D4AA;">2.</strong> 开启换行 — wrap: true</p>
        <p><strong style="color:#00D4AA;">3.</strong> 调整布局 — 增加文本框宽度</p>

  # 注意事项
  - elementId: note-label
    elementType: text
    bounds: [60, 508, 400, 26]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>FIX GUIDELINES</p>

  # 注意事项卡片
  - elementId: note-bg
    elementType: shape
    bounds: [60, 545, 1160, 110]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: note-content
    elementType: text
    bounds: [82, 555, 1116, 90]
    content:
      fontSize: 15
      color: "$text"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.7
      text: |
        <p><span style="color:#3B6BFF;"><strong>并行修复</strong></span>  单次响应中尽可能并行调用 edit_file，批量修复多个问题</p>
        <p><span style="color:#00D4AA;"><strong>保持边距</strong></span>  调整 bounds 后检查与其他元素的间距，避免贴边</p>
        <p><span style="color:#F5A623;"><strong>公共元素</strong></span>  不动导航栏、标题等跨页公共元素的位置，优先调整内容布局</p>

  # 页码
  - elementId: page-num
    elementType: text
    bounds: [1170, 680, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>16</p>
