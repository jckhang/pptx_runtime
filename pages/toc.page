pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  # 左侧大标题 CONTENTS
  - elementId: toc-label
    elementType: text
    bounds: [60, 80, 340, 50]
    content:
      fontSize: 16
      color: "$secondary"
      fontFamily: "Liter"
      letterSpacing: 6
      wrap: false
      text: |
        <p>CONTENTS</p>

  # 左侧中文标题
  - elementId: toc-title
    elementType: text
    bounds: [60, 140, 340, 40]
    content:
      fontSize: 28
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>目录</strong></p>

  # 左侧装饰线
  - elementId: toc-deco
    elementType: shape
    bounds: [60, 200, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 章节卡片 1
  - elementId: card-bg-1
    elementType: shape
    bounds: [440, 80, 380, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: card-bar-1
    elementType: shape
    bounds: [440, 80, 4, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: card-num-1
    elementType: text
    bounds: [464, 90, 70, 50]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>01</strong></p>

  - elementId: card-text-1
    elementType: text
    bounds: [540, 95, 260, 70]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      lineHeight: 1.4
      text: |
        <p><strong>Swarm 架构设计</strong></p>
        <p><span style="font-size:14px; color:#7A8B9F;">主代理与子代理的分工协作</span></p>

  # 章节卡片 2
  - elementId: card-bg-2
    elementType: shape
    bounds: [440, 200, 380, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: card-bar-2
    elementType: shape
    bounds: [440, 200, 4, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: card-num-2
    elementType: text
    bounds: [464, 210, 70, 50]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>02</strong></p>

  - elementId: card-text-2
    elementType: text
    bounds: [540, 215, 260, 70]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      lineHeight: 1.4
      text: |
        <p><strong>PPTD 中间格式</strong></p>
        <p><span style="font-size:14px; color:#7A8B9F;">面向 AI 的 OOXML 简化抽象层</span></p>

  # 章节卡片 3
  - elementId: card-bg-3
    elementType: shape
    bounds: [440, 320, 380, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: card-bar-3
    elementType: shape
    bounds: [440, 320, 4, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: card-num-3
    elementType: text
    bounds: [464, 330, 70, 50]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>03</strong></p>

  - elementId: card-text-3
    elementType: text
    bounds: [540, 335, 260, 70]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      lineHeight: 1.4
      text: |
        <p><strong>七步标准化工作流</strong></p>
        <p><span style="font-size:14px; color:#7A8B9F;">从需求到交付的完整流程</span></p>

  # 章节卡片 4
  - elementId: card-bg-4
    elementType: shape
    bounds: [440, 440, 380, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: card-bar-4
    elementType: shape
    bounds: [440, 440, 4, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: card-num-4
    elementType: text
    bounds: [464, 450, 70, 50]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>04</strong></p>

  - elementId: card-text-4
    elementType: text
    bounds: [540, 455, 260, 70]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      lineHeight: 1.4
      text: |
        <p><strong>质量控制体系</strong></p>
        <p><span style="font-size:14px; color:#7A8B9F;">内置 Checker 与自动化修复</span></p>

  # 章节卡片 5
  - elementId: card-bg-5
    elementType: shape
    bounds: [440, 560, 380, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  - elementId: card-bar-5
    elementType: shape
    bounds: [440, 560, 4, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: card-num-5
    elementType: text
    bounds: [464, 570, 70, 50]
    content:
      fontSize: 36
      color: "$primary"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>05</strong></p>

  - elementId: card-text-5
    elementType: text
    bounds: [540, 575, 260, 70]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      lineHeight: 1.4
      text: |
        <p><strong>核心设计思想</strong></p>
        <p><span style="font-size:14px; color:#7A8B9F;">关注点分离与质量内建</span></p>

  # 右侧装饰竖线
  - elementId: right-deco
    elementType: shape
    bounds: [860, 80, 1, 580]
    shapeName: rect
    fill:
      type: solid
      color: "$divider"

  # 页码
  - elementId: page-num
    elementType: text
    bounds: [1170, 680, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>02</p>
