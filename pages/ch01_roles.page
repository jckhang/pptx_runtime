pageType: content
background:
  type: solid
  color: "$background"
elements:
  # 页面标题
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 700, 40]
    content:
      style: "$pageTitle"
      wrap: false
      text: |
        <p><strong>角色分工矩阵</strong></p>

  # 标题装饰线
  - elementId: title-line
    elementType: shape
    bounds: [60, 88, 1160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$divider"

  # 主代理卡片背景
  - elementId: main-card-bg
    elementType: shape
    bounds: [60, 110, 565, 310]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  # 主代理色带
  - elementId: main-card-bar
    elementType: shape
    bounds: [60, 110, 5, 310]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 主代理图标
  - elementId: main-icon
    elementType: icon
    bounds: [85, 130, 28, 28]
    iconName: "fas:user-tie"
    fill:
      type: solid
      color: "$primary"

  # 主代理标题
  - elementId: main-label
    elementType: text
    bounds: [122, 128, 230, 34]
    content:
      fontSize: 22
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>主代理 Main Agent</strong></p>

  # 主代理职责列表
  - elementId: main-duties
    elementType: text
    bounds: [85, 175, 520, 225]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.8
      text: |
        <p><span style="color:#3B6BFF;">&#9632;</span> 需求分析与受众画像</p>
        <p><span style="color:#3B6BFF;">&#9632;</span> 视觉设计 — 产出 design.md</p>
        <p><span style="color:#3B6BFF;">&#9632;</span> 内容规划 — 产出 outline.md</p>
        <p><span style="color:#3B6BFF;">&#9632;</span> 生成 .pptd 主入口文件</p>
        <p><span style="color:#3B6BFF;">&#9632;</span> 质量检查与修复</p>
        <p><span style="color:#3B6BFF;">&#9632;</span> 子代理任务派发与协调</p>

  # 子代理卡片背景
  - elementId: sub-card-bg
    elementType: shape
    bounds: [655, 110, 565, 310]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"

  # 子代理色带
  - elementId: sub-card-bar
    elementType: shape
    bounds: [655, 110, 5, 310]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  # 子代理图标
  - elementId: sub-icon
    elementType: icon
    bounds: [680, 130, 28, 28]
    iconName: "fas:robot"
    fill:
      type: solid
      color: "$accent"

  # 子代理标题
  - elementId: sub-label
    elementType: text
    bounds: [717, 128, 260, 34]
    content:
      fontSize: 22
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p><strong>子代理 Sub Agent</strong></p>

  # 子代理职责列表
  - elementId: sub-duties
    elementType: text
    bounds: [680, 175, 520, 225]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.8
      text: |
        <p><span style="color:#00D4AA;">&#9632;</span> 读取 design.md 视觉规范</p>
        <p><span style="color:#00D4AA;">&#9632;</span> 读取 outline.md 内容大纲</p>
        <p><span style="color:#00D4AA;">&#9632;</span> 按指引生成 .page 文件</p>
        <p><span style="color:#00D4AA;">&#9632;</span> 执行自检（--pages 参数）</p>
        <p><span style="color:#FF6B6B;">&#9632;</span> 禁止创建子代理</p>
        <p><span style="color:#FF6B6B;">&#9632;</span> 禁止修改 .pptd 主文件</p>

  # 底部关键规则提示
  - elementId: rule-bg
    elementType: shape
    bounds: [60, 445, 1160, 60]
    shapeName: rect
    fill:
      type: solid
      color: "#3B6BFF18"

  - elementId: rule-bar
    elementType: shape
    bounds: [60, 445, 4, 60]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: rule-text
    elementType: text
    bounds: [82, 452, 1110, 46]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter, MiSans"
      lineHeight: 1.5
      align: [left, middle]
      text: |
        <p><span style="color:#3B6BFF;"><strong>核心原则</strong></span>：主代理负责"设计与决策"，子代理负责"执行与构建"，两者不可越界</p>

  # 信息流图示
  - elementId: flow-label
    elementType: text
    bounds: [60, 530, 200, 30]
    content:
      fontSize: 16
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      wrap: false
      text: |
        <p>信息流向</p>

  # 流程框 1
  - elementId: flow-box-1
    elementType: shape
    bounds: [60, 570, 200, 50]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: flow-text-1
    elementType: text
    bounds: [60, 570, 200, 50]
    content:
      fontSize: 14
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>主代理设计</p>

  # 箭头 1
  - elementId: flow-arrow-1
    elementType: shape
    bounds: [270, 590, 60, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border:
      style: solid
      width: 2
      color: "$primary"

  # 流程框 2
  - elementId: flow-box-2
    elementType: shape
    bounds: [340, 570, 200, 50]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: flow-text-2
    elementType: text
    bounds: [340, 570, 200, 50]
    content:
      fontSize: 14
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>子代理构建</p>

  # 箭头 2
  - elementId: flow-arrow-2
    elementType: shape
    bounds: [550, 590, 60, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border:
      style: solid
      width: 2
      color: "$accent"

  # 流程框 3
  - elementId: flow-box-3
    elementType: shape
    bounds: [620, 570, 200, 50]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: flow-text-3
    elementType: text
    bounds: [620, 570, 200, 50]
    content:
      fontSize: 14
      color: "#FFFFFF"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>主代理检查</p>

  # 箭头 3
  - elementId: flow-arrow-3
    elementType: shape
    bounds: [830, 590, 60, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border:
      style: solid
      width: 2
      color: "$primary"

  # 流程框 4
  - elementId: flow-box-4
    elementType: shape
    bounds: [900, 570, 200, 50]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$primary"

  - elementId: flow-text-4
    elementType: text
    bounds: [900, 570, 200, 50]
    content:
      fontSize: 14
      color: "$text"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>交付 .pptd</p>

  # 页码
  - elementId: page-num
    elementType: text
    bounds: [1170, 680, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>04</p>
