pageType: final
background:
  type: solid
  color: "$background"
elements:
  # 装饰圆环
  - elementId: deco-ring-1
    elementType: shape
    bounds: [440, 100, 400, 400]
    shapeName: donut
    adjustments: [48000]
    fill:
      type: solid
      color: "$primary"
    opacity: 0.06

  # 装饰圆环 2
  - elementId: deco-ring-2
    elementType: shape
    bounds: [490, 150, 300, 300]
    shapeName: donut
    adjustments: [45000]
    fill:
      type: solid
      color: "$primary"
    opacity: 0.1

  # 中心装饰节点
  - elementId: center-node
    elementType: shape
    bounds: [616, 276, 48, 48]
    shapeName: ellipse
    fill:
      type: solid
      color: "$primary"
    opacity: 0.9

  # 卫星节点 1
  - elementId: sat-1
    elementType: shape
    bounds: [560, 200, 20, 20]
    shapeName: ellipse
    fill:
      type: solid
      color: "$accent"
    opacity: 0.7

  # 卫星节点 2
  - elementId: sat-2
    elementType: shape
    bounds: [700, 230, 16, 16]
    shapeName: ellipse
    fill:
      type: solid
      color: "$primary"
    opacity: 0.5

  # 卫星节点 3
  - elementId: sat-3
    elementType: shape
    bounds: [520, 340, 14, 14]
    shapeName: ellipse
    fill:
      type: solid
      color: "$secondary"
    opacity: 0.6

  # 连接线
  - elementId: conn-s1
    elementType: shape
    bounds: [580, 220, 56, 76]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$primary"
    opacity: 0.3

  - elementId: conn-s2
    elementType: shape
    bounds: [664, 300, 36, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 1
      color: "$accent"
    opacity: 0.3

  # 主标题
  - elementId: thanks-title
    elementType: text
    bounds: [240, 380, 800, 70]
    content:
      fontSize: 48
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>谢谢观看</strong></p>

  # 副标题
  - elementId: thanks-subtitle
    elementType: text
    bounds: [240, 460, 800, 35]
    content:
      fontSize: 20
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>PPTX Swarm — 多智能体协作的 PPT 生成系统</p>

  # 装饰线
  - elementId: thanks-deco
    elementType: shape
    bounds: [580, 510, 120, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  # 提示文字
  - elementId: hint-text
    elementType: text
    bounds: [340, 530, 600, 30]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>点击卡片即可预览和导出为 PPTX 格式</p>

  # 底部标识
  - elementId: footer-text
    elementType: text
    bounds: [60, 670, 400, 24]
    content:
      style: "$caption"
      text: |
        <p>PPTX Swarm Architecture Deep Dive</p>

  # 页码
  - elementId: page-num
    elementType: text
    bounds: [1170, 680, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>19</p>
